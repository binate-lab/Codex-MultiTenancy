@page "/tenants"
@using ABCShared.Library.Constants

@attribute [ShouldHavePermission(SchoolAction.Read, SchoolFeature.Tenants)]

<Header OnReturn="ReturnClicked" Title="Organisation" Description="Gestion des Ets"/>

<MudTable Items="TenantList"
Loading="_isLoading"
LoadingProgressColor="Color.Info"
Elevation="25">
    <ToolBarContent>
        <MudFab StartIcon="@Icons.Material.Filled.Add"
        OnClick="OnBoardNewTenantAsync"
        Size="Size.Small" 
        IconSize="Size.Medium"
        Class="mr-2"/>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Organisation</MudTh>
        <MudTh>Nom Admin</MudTh>
        <MudTh>Prénoms Admin</MudTh>
        <MudTh>Email</MudTh>
        <MudTh>Date d'expiration</MudTh>
        <MudTh>Actif</MudTh>
        <MudTh Style="text-align:right">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd> @context.Name</MudTd>
        <MudTd> @context.FirstName</MudTd>
        <MudTd> @context.LastName</MudTd>
        <MudTd> @context.Email</MudTd>
        <MudTd> @context.ValidUpTo.ToString("dd MMM yyyy")</MudTd>
        <MudTd> 
            <MudCheckBox @bind-Value="@context.IsActive" 
            ReadOnly 
            Color="Color.Secondary"
            />
        </MudTd>
        <MudTd Style="text-align:right">
            <MudMenu Icon="@Icons.Material.Filled.MoreVert"
            Size="Size.Small"
            Color="Color.Secondary"
            TransformOrigin="Origin.BottomLeft" 
            AnchorOrigin="Origin.BottomLeft">
                <MudMenuItem OnClick="@(() => UpgradeSubscriptionAsync(context))">Upgrader</MudMenuItem>
                @if (context.IsActive)
                {
                    <MudMenuItem OnClick="@(() => ActivateOrDeactivativeAsync(context))">Désactivation</MudMenuItem>
                }
                else
                {
                    <MudMenuItem OnClick="@(() => ActivateOrDeactivativeAsync(context))">Activation</MudMenuItem>
                }
                <MudMenuItem OnClick="@(() => DeleteTenantAsync(context))" Style="color: var(--mud-palette-error);">Supprimer</MudMenuItem>

            </MudMenu>
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager RowsPerPageString="LignesParPage" InfoFormat="{first_item}-{last_item} sur {all_items}" />
    </PagerContent>
</MudTable>
