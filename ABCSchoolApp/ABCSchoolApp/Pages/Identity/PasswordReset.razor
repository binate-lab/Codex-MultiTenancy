<MudForm @ref="_form" Model="ChangePasswordRequest">
    <MudCard Elevation="25">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText>Réinitialiser le mot de passe</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="ChangePasswordRequest.NewPassword"
                        Variant="Variant.Outlined"
                        Label="Nouveau mot de passe"
                        InputType="_newPasswordInput"
                        Adornment="Adornment.End"
                        AdornmentIcon="@_newPasswordInputIcon"
                        OnAdornmentClick="@(() => TogglePasswordVisibility(true))"/>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="ChangePasswordRequest.ConfirmNewPassword"
                                  Variant="Variant.Outlined"
                                  Label="Confirmation du nouveau mot de passe"
                                  InputType="_newPasswordInput"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@_newPasswordInputIcon"
                                  OnAdornmentClick="@(() => TogglePasswordVisibility(true))" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="ChangePasswordRequest.CurrentPassword"
                                  Label="Mot de passe actuel"
                                  Variant="Variant.Outlined"
                                  InputType="_currentPasswordInput"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@_currentPasswordInputIcon"
                                  OnAdornmentClick="@(() => TogglePasswordVisibility(false))" />
                </MudItem>
            </MudGrid>
        </MudCardContent>
        <MudCardActions>
            <MudButton Variant="Variant.Filled"
                OnClick="ResetPasswordAsync"
                Color="Color.Primary"
                Size="Size.Small"
                Class="ml-auto">
                Réinitialiser le mot de passe
            </MudButton>
        </MudCardActions>
    </MudCard>
</MudForm>
