<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@InputIcon" Class="mr-3 mb-n1" />
            @Title
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_valeur"
                      Label="@Label"
                      Variant="Variant.Outlined"
                      Lines="2"
                      AutoFocus="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Filled" Class="mr-3 mb-n2">Annuler</MudButton>
        <MudButton OnClick="Confirmer"
                   Color="@Color"
                   Variant="Variant.Filled"
                   Disabled="@(string.IsNullOrWhiteSpace(_valeur))">@ButtonText</MudButton>
    </DialogActions>
</MudDialog>
