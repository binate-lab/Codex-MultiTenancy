@* Confirmation du changement de niveau d'un élève (grille Scolarités). « Non » est le bouton
   FOCALISÉ par défaut au clavier : l'utilisateur doit explicitement choisir « Oui » (un simple
   Entrée/Espace déclenche donc « Non » = annulation). Le changement de niveau touche les
   frais/l'échéancier, on ne le fait pas par erreur. *@
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.SwapVert" Class="mr-3 mb-n1" />
            Changement de niveau
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText>Vous décidez de changer <b>@Nom @Prenoms</b> de niveau ?</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton @ref="_boutonNon" OnClick="Non" Variant="Variant.Filled" Class="mr-3 mb-n2">Non</MudButton>
        <MudButton OnClick="Oui" Color="Color.Primary" Variant="Variant.Filled">Oui</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string Nom { get; set; } = string.Empty;
    [Parameter] public string Prenoms { get; set; } = string.Empty;

    private MudButton? _boutonNon;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _boutonNon is not null)
            await _boutonNon.FocusAsync();
    }

    private void Oui() => MudDialog.Close(DialogResult.Ok(true));
    private void Non() => MudDialog.Cancel();
}
