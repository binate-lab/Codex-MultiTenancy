@namespace TrajanEcoleApp.Components

@if (DoitAfficher)
{
@if (_isOpen)
{
    <MudPaper Elevation="8"
              Class="d-flex flex-column"
              Style="@($"{StylePanneau} z-index: 1400; overflow: hidden; border-radius: 12px;")">

        <MudToolBar Dense="true" Style="background-color: #E65100; color: white;">
            <MudIcon Icon="@Icons.Material.Filled.SupportAgent" Class="mr-2" />
            <MudText Typo="Typo.subtitle1">Trajan Assistant</MudText>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Color="Color.Inherit"
                           Size="Size.Small"
                           OnClick="Toggle" />
        </MudToolBar>

        <div style="flex: 1 1 auto; overflow-y: auto; padding: 12px; background-color: var(--mud-palette-background-grey);">
            @if (_messages.Count == 0)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    Bonjour 👋 Je suis Sophia l'assistante Trajan. Posez-moi une question sur l'utilisation de l'application
                    (organisations, écoles, rôles, permissions...).
                </MudText>
            }

            @foreach (var message in _messages)
            {
                var isUser = message.Role == "user";
                <div class="d-flex mb-2" style="@(isUser ? "justify-content: flex-end;" : "justify-content: flex-start;")">
                    <MudPaper Elevation="0"
                              Class="pa-2"
                              Style="@($"max-width: 80%; border-radius: 10px; white-space: pre-wrap; word-break: break-word; {(isUser ? "background-color:#4EC9B0; color:white;" : "background-color:var(--mud-palette-surface);")}")">
                        <MudText Typo="Typo.body2">@message.Content</MudText>
                    </MudPaper>
                </div>
            }

            @if (_isLoading)
            {
                <div class="d-flex justify-start mb-2">
                    <MudPaper Elevation="0" Class="pa-2" Style="border-radius: 10px;">
                        <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Secondary" />
                    </MudPaper>
                </div>
            }
        </div>

        <MudDivider />

        <div class="d-flex align-center pa-2" style="gap: 4px;">
            <MudTextField @bind-Value="_input"
                          Placeholder="Écrivez votre message..."
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          OnKeyDown="OnKeyDown"
                          Disabled="_isLoading"
                          Class="flex-grow-1" />
            <MudIconButton Icon="@Icons.Material.Filled.Send"
                           Color="Color.Primary"
                           Disabled="@(_isLoading || string.IsNullOrWhiteSpace(_input))"
                           OnClick="SendAsync" />
        </div>
    </MudPaper>
}

<button @onclick="Toggle"
        title="Je suis Sophia pour vous assister"
        style="@($@"{StyleBouton} z-index: 1400;
               width: 56px; height: 56px; border-radius: 50%; border: none; cursor: pointer;
               background-color: #E65100; color: white; padding: 0; overflow: hidden;
               box-shadow: 0 3px 5px -1px rgba(0,0,0,.2), 0 6px 10px 0 rgba(0,0,0,.14), 0 1px 18px 0 rgba(0,0,0,.12);
               display: flex; align-items: center; justify-content: center;")">
    @if (_isOpen)
    {
        <MudIcon Icon="@Icons.Material.Filled.Close" Style="color: white;" />
    }
    else
    {
        <img src="images/ChatImg.png" alt="Assistante Trajan"
             style="width: 100%; height: 100%; object-fit: cover;" />
    }
</button>
}
