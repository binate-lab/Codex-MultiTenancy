@page "/scolarites"
@layout SchoolLayout

<MudPaper Elevation="6" Class="ma-2">
    <div class="acc-window">

        <!-- Bandeau : titre + année + Fermer -->
        <div class="acc-titlebar">
            <div class="d-flex align-center gap-3">
                <span class="acc-title">Scolarités</span>
                <span class="acc-year">@_annee</span>
            </div>
            <div class="d-flex align-center gap-2">
                <MudButton Variant="Variant.Text" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Close"
                           OnClick="Fermer">Fermer</MudButton>
            </div>
        </div>

        <!-- ============ Barre de filtres ============ -->
        <div class="acc-filterbar">
            @* Tous les filtres sur UNE ligne, dans l'ordre de tabulation
               (Nom -> Prénoms -> Matricule -> N° Inscription -> Niveau -> Classe ->
               Statut -> Inscrit). Le Tab / Shift+Tab suit naturellement l'ordre du DOM. *@
            <div class="acc-fgroup">
                <label class="acc-flabel">Nom :</label>
                <MudTextField @bind-Value="_fNom" Immediate="true" Clearable="true"
                              Placeholder="Nom…"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-fmaj" />
            </div>
            <div class="acc-fgroup">
                <label class="acc-flabel">Prénoms :</label>
                <MudTextField @bind-Value="_fPrenoms" Immediate="true" Clearable="true"
                              Placeholder="Prénoms…"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield" />
            </div>
            <div class="acc-fgroup">
                <label class="acc-flabel">Matricule :</label>
                <MudTextField @bind-Value="_fMatricule" Immediate="true" Clearable="true"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-yellow acc-fmatricule" />
            </div>
            <div class="acc-fgroup">
                <label class="acc-flabel">N° Inscription :</label>
                <MudTextField @bind-Value="_fNumOrdre" Immediate="true" Clearable="true"
                              Placeholder="N°…"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-yellow acc-fnumordre" />
            </div>
            <div class="acc-fgroup">
                <label class="acc-flabel">Niveau :</label>
                <MudSelect Value="_fNiveau" ValueChanged="OnFiltreNiveauChanged" T="string" Clearable="true" Dense="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-fnarrow">
                    <MudSelectItem Value="@("")">Tous</MudSelectItem>
                    @foreach (var n in _niveaux)
                    {
                        <MudSelectItem Value="@n">@n</MudSelectItem>
                    }
                </MudSelect>
            </div>
            <div class="acc-fgroup">
                <label class="acc-flabel">Classe :</label>
                @* Déroulante en cascade : ne montre que les classes du niveau filtré
                   (toutes les classes si aucun niveau n'est choisi). *@
                <MudSelect @bind-Value="_fClasse" T="string" Clearable="true" Dense="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-fnarrow acc-fclasse">
                    <MudSelectItem Value="@("")">Toutes</MudSelectItem>
                    @foreach (var cl in ClassesFiltre)
                    {
                        <MudSelectItem Value="@cl.Libelle">@cl.Libelle</MudSelectItem>
                    }
                </MudSelect>
            </div>
            <div class="acc-fgroup">
                <label class="acc-flabel">Statut :</label>
                <MudSelect @bind-Value="_fStatut" T="string" Dense="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-fnarrow">
                    <MudSelectItem Value="@("Tous")">Tous</MudSelectItem>
                    <MudSelectItem Value="@("Aff")">Aff</MudSelectItem>
                    <MudSelectItem Value="@("Naff")">Naff</MudSelectItem>
                </MudSelect>
            </div>
            <div class="acc-fgroup">
                <label class="acc-flabel">Inscrit :</label>
                <MudSelect @bind-Value="_fInscrit" T="string" Dense="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-fnarrow">
                    <MudSelectItem Value="@("Tous")">Tous</MudSelectItem>
                    <MudSelectItem Value="@("Oui")">Oui</MudSelectItem>
                    <MudSelectItem Value="@("Non")">Non</MudSelectItem>
                </MudSelect>
            </div>
            <div class="acc-fgroup">
                <label class="acc-flabel">Actif :</label>
                <MudSelect @bind-Value="_fActif" T="string" Dense="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-fnarrow">
                    <MudSelectItem Value="@("Tous")">Tous</MudSelectItem>
                    <MudSelectItem Value="@("Oui")">Oui</MudSelectItem>
                    <MudSelectItem Value="@("Non")">Non</MudSelectItem>
                </MudSelect>
            </div>
            <div class="acc-fgroup">
                <label class="acc-flabel">Transport :</label>
                <MudSelect @bind-Value="_fTransport" T="string" Dense="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-fnarrow">
                    <MudSelectItem Value="@("Tous")">Tous</MudSelectItem>
                    <MudSelectItem Value="@("Oui")">Oui</MudSelectItem>
                    <MudSelectItem Value="@("Non")">Non</MudSelectItem>
                </MudSelect>
            </div>
            <MudButton OnClick="Effacer" Variant="Variant.Outlined" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.FilterAltOff" Class="ml-auto">Effacer</MudButton>
        </div>

        <!-- ============ Zone rouge : liste des élèves ============ -->
        <!-- La table est enveloppée dans un div qui porte l'attribut de scope CSS :
             c'est lui qui permet aux sélecteurs ::deep d'atteindre les <td> de MudTable. -->
        <div class="acc-grid acc-grid-eleves mt-1">
        <MudTable T="EleveScolariteRow" Items="Filtered" Dense="true" Hover="true" Bordered="true"
                  RowsPerPage="5" OnRowClick="OnRowClick" RowClassFunc="ClasseLigne">
            <HeaderContent>
                <MudTh Style="width:96px">Matricule</MudTh>
                <MudTh Style="width:104px">Tél. Correspondant</MudTh>
                <MudTh>Nom</MudTh>
                <MudTh>Prénoms</MudTh>
                <MudTh Style="width:52px; text-align:center">Actif</MudTh>
                <MudTh Style="width:52px; text-align:center">Inscrit</MudTh>
                <MudTh Style="width:70px">Statut</MudTh>
                <MudTh Style="width:74px">Niveau</MudTh>
                <MudTh Style="width:64px">Classe</MudTh>
                <MudTh Style="width:96px">Transport</MudTh>
                <MudTh Style="text-align:right">Net à payer</MudTh>
                <MudTh Style="text-align:right">Inscription</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Matricule">@context.Matricule</MudTd>
                <MudTd DataLabel="Tél. Correspondant" data-col="Tel" data-eleve-id="@context.Id">
                    <MudTextField T="string" Value="@context.TelCorrespondant"
                                  ValueChanged="@(v => OnTelChanged(context, v))"
                                  Immediate="false" Margin="Margin.Dense"
                                  Variant="Variant.Text" Underline="false"
                                  Class="acc-cell-input acc-cell-tel" />
                </MudTd>
                <MudTd DataLabel="Nom" Class="acc-cell-nom">@context.Nom</MudTd>
                <MudTd DataLabel="Prénoms" Class="acc-cell-prenom">@context.Prenoms</MudTd>
                <MudTd DataLabel="Actif" Style="text-align:center">
                    <MudIcon Size="Size.Small"
                             Icon="@(context.Actif ? Icons.Material.Filled.CheckBox : Icons.Material.Filled.CheckBoxOutlineBlank)" />
                </MudTd>
                <MudTd DataLabel="Inscrit" Style="text-align:center">
                    <MudIcon Size="Size.Small"
                             Icon="@(context.Inscrit ? Icons.Material.Filled.CheckBox : Icons.Material.Filled.CheckBoxOutlineBlank)" />
                </MudTd>
                <MudTd DataLabel="Statut" data-col="Statut" data-eleve-id="@context.Id">
                    <MudSelect T="string" Value="@context.Statut"
                               ValueChanged="@(v => OnStatutChanged(context, v))"
                               Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Underline="false"
                               Class="acc-cell-select">
                        <MudSelectItem Value="@("Aff")">Aff</MudSelectItem>
                        <MudSelectItem Value="@("Naff")">Naff</MudSelectItem>
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="Niveau" data-col="Niveau" data-eleve-id="@context.Id">
                    <MudSelect T="string" Value="@context.Niveau"
                               ValueChanged="@(v => OnNiveauChanged(context, v))"
                               Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Underline="false"
                               Class="acc-cell-select">
                        @foreach (var n in _niveaux)
                        {
                            <MudSelectItem Value="@n">@n</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="Classe" data-col="Classe" data-eleve-id="@context.Id">
                    @* Classe = sélecteur alimenté par le référentiel structures (classes du
                       niveau de la ligne, pour l'année en cours) — plus de saisie libre. *@
                    <MudSelect T="string" Value="@context.Classe"
                               ValueChanged="@(v => OnClasseChanged(context, v))"
                               Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Underline="false"
                               Class="acc-cell-select">
                        @foreach (var cl in ClassesPour(context.Niveau))
                        {
                            <MudSelectItem Value="@cl.Libelle">@cl.Libelle</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="Transport" data-col="Transport" data-eleve-id="@context.Id">
                    @* Zone de transport : « Aucun » retire le transport ; une zone ajoute la
                       part transport de chaque mois à la mensualité correspondante. *@
                    <MudSelect T="string" Value="@context.ZoneTransport"
                               ValueChanged="@(v => OnZoneTransportChangedAsync(context, v))"
                               Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Underline="false"
                               Disabled="_transportEnCours" Class="acc-cell-select">
                        <MudSelectItem Value="@("")">Aucun</MudSelectItem>
                        @foreach (var z in _zonesTransport)
                        {
                            <MudSelectItem Value="@z.Zone">@z.Zone</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="Net à payer" Style="text-align:right">@Fmt(context.NetAPayer)</MudTd>
                <MudTd DataLabel="Inscription" Style="text-align:right">@Fmt(context.Inscription)</MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Class="pa-2">Aucun élève ne correspond au filtre.</MudText>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 5, 10, 25 }" RowsPerPageString="Lignes par page" />
            </PagerContent>
        </MudTable>
        </div>

        <div class="acc-gridfoot">
            <MudText Typo="Typo.caption">@Filtered.Count() élève(s) affiché(s)</MudText>
            <MudText Typo="Typo.caption" Class="acc-demo-note">
                Source : Scolarite (ScolariteDb).
            </MudText>
        </div>

        @* ============ Versements de l'élève sélectionné (calque Access) ============ *@
        @if (_sel is not null)
        {
            <div class="svt-titre">
                Les versements de :&nbsp;<b>@_sel.Nom @_sel.Prenoms</b>&nbsp;
                <span class="svt-titre-niveau">en : @_sel.Classe (N° @_sel.NumOrdre)</span>
            </div>

            <div class="svt-zone">
                @* --- Bloc synthèse (Total Frais / Payé / Reste) --- *@
                <div class="svt-resume">
                    <div class="svt-resume-titre">Point de l'élève</div>
                    <div class="svt-resume-ligne"><span>Total Frais :</span><b>@Fmt(_resume?.FraisScolarite ?? 0)</b></div>
                    <div class="svt-resume-ligne"><span>Réduction :</span><b>@Fmt(_resume?.TotalReduction ?? 0)</b></div>
                    <div class="svt-resume-ligne"><span>Payé :</span><b>@Fmt(_resume?.TotalVerse ?? 0)</b></div>
                    <div class="svt-resume-ligne svt-reste"><span>Reste :</span><b>@Fmt(_resume?.Reste ?? 0)</b></div>
                    @if ((_resume?.Credit ?? 0) > 0)
                    {
                        <div class="svt-resume-ligne"><span>Crédit :</span><b>@Fmt(_resume.Credit)</b></div>
                    }
                </div>

                @* --- Sous-form bleu ciel : saisie d'un versement, rangee comme dans
                       Access : Date + Ref. operation a gauche ; MONTANT/Nouveau puis
                       Nature et Mode (libelles a gauche des listes) a droite ;
                       Valider en bas a droite. --- *@
                <div class="svt-saisie">
                    <div class="svt-cols">
                        <div class="svt-col-droite">
                            @* Date et MONTANT sur la meme ligne, pousses a droite. *@
                            <div class="svt-ligne svt-ligne-montant">
                                <label>Date :</label>
                                <MudDatePicker @bind-Date="_vDate" Editable="true" DateFormat="dd/MM/yyyy"
                                               Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-datemask" />
                                <label class="svt-montant-label">MONTANT :</label>
                                <MudNumericField T="decimal" @bind-Value="_vMontant" HideSpinButtons="true" Min="0"
                                                 Format="#,0" Culture="@_fr"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense" Class="svt-montant" />
                                <MudButton OnClick="NouveauVersement" Variant="Variant.Outlined" Size="Size.Small"
                                           Class="svt-btn-nouveau">Nouveau</MudButton>
                            </div>
                            <div class="svt-ligne">
                                <label>Nature du versement :</label>
                                @* Natures alimentées par le référentiel configurable de l'école
                                   (module Economat → Nature versement) : lignes « Visible », triées. *@
                                <MudSelect T="string" @bind-Value="_vNature" Variant="Variant.Outlined" Margin="Margin.Dense" Class="svt-nav-nature">
                                    @foreach (var n in _natures)
                                    {
                                        <MudSelectItem Value="@n.Libelle">@n.Libelle</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>
                            <div class="svt-ligne svt-ligne-resserre">
                                <label>Mode de paiement :</label>
                                <MudSelect T="string" @bind-Value="_vMode" Variant="Variant.Outlined" Margin="Margin.Dense" Class="svt-nav-mode">
                                    <MudSelectItem Value="@("Espèce")">Espèce</MudSelectItem>
                                    <MudSelectItem Value="@("Chèque")">Chèque</MudSelectItem>
                                    <MudSelectItem Value="@("Virement")">Virement</MudSelectItem>
                                    <MudSelectItem Value="@("Mobile Money")">Mobile Money</MudSelectItem>
                                </MudSelect>
                            </div>
                            <div class="svt-ligne svt-ligne-resserre">
                                <label>Réf. opération :</label>
                                <MudTextField T="string" @bind-Value="_vRef" Variant="Variant.Outlined"
                                              Margin="Margin.Dense" Class="acc-yellow svt-nav-ref" />
                            </div>
                        </div>
                    </div>
                    <div class="svt-valider-box">
                        <MudTooltip Text="@(_vEnEdition is null ? "Valider le versement" : "Enregistrer la modification")">
                            <MudButton OnClick="ValiderVersementAsync" Variant="Variant.Filled"
                                       Color="@(_vEnEdition is null ? Color.Primary : Color.Warning)"
                                       Size="Size.Small" Disabled="_vEnCours"
                                       Class="@(_vEnEdition is null ? "svt-btn-valider" : "svt-btn-valider svt-btn-modif")"
                                       StartIcon="@(_vEnEdition is null ? Icons.Material.Filled.Check : Icons.Material.Filled.Save)">
                                @(_vEnEdition is null ? "Valider" : "Modifier")
                            </MudButton>
                        </MudTooltip>
                        @if (_vEnEdition is not null)
                        {
                            <MudTooltip Text="Annuler la modification">
                                <MudButton OnClick="NouveauVersement" Variant="Variant.Outlined" Color="Color.Default"
                                           Size="Size.Small" Disabled="_vEnCours" Class="svt-btn-annuler ml-2"
                                           StartIcon="@Icons.Material.Filled.Close">Annuler</MudButton>
                            </MudTooltip>
                        }
                        <MudTooltip Text="Aperçu du reçu (comme les listes : à l'écran, puis impression)">
                            <MudButton OnClick="OuvrirRecuApercu" Variant="Variant.Outlined" Color="Color.Primary"
                                       Size="Size.Small" Disabled="_sel is null" Class="svt-btn-recu ml-2"
                                       StartIcon="@Icons.Material.Filled.Visibility">Aperçu</MudButton>
                        </MudTooltip>
                        <MudTooltip Text="Télécharger le reçu de paiement en PDF">
                            <MudButton OnClick="TelechargerRecuAsync" Variant="Variant.Outlined" Color="Color.Primary"
                                       Size="Size.Small" Disabled="_recuEnCours" Class="svt-btn-recu ml-2"
                                       StartIcon="@Icons.Material.Filled.PictureAsPdf">Reçu PDF</MudButton>
                        </MudTooltip>
                        @* SMS : le bouton n'envoie que si la case juste à droite est cochée.
                           La case mémorise (ou non) son état pour les prochaines ouvertures. *@
                        <MudTooltip Text="Envoyer le reçu par SMS (coche la case pour activer)">
                            <MudButton OnClick="EnvoyerSmsAsync" Variant="Variant.Outlined" Color="Color.Primary"
                                       Size="Size.Small" Disabled="_smsEnCours" Class="svt-btn-sms ml-2"
                                       StartIcon="@Icons.Material.Filled.Sms">SMS</MudButton>
                        </MudTooltip>
                        <MudCheckBox T="bool" Value="_smsCoche" ValueChanged="OnSmsCocheChangedAsync"
                                     Dense="true" Size="Size.Small" Color="Color.Primary" Class="svt-chk-sms" />
                    </div>
                </div>

                @* Echeancier individuel de l'eleve (Inscription puis Septembre -> Mai),
                   statut Paye / Partiel / NonPaye par ligne, comme la grille de droite
                   du form Access. *@
                <div class="svt-echeancier-slot">
                    <div class="svt-ech-titre">Échéancier</div>
                    <div class="svt-ech-grid">
                        @if (_echeancier.Count == 0)
                        {
                            <div class="svt-ech-vide">Aucun échéancier pour cet élève.</div>
                        }
                        else
                        {
                            <table class="svt-ech-table">
                                <thead>
                                    <tr><th>Échéance</th><th>Montant</th><th>Payé</th><th>Statut</th><th>Reste</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var e in _echeancier)
                                    {
                                        <tr class="@(e.EnRetard ? "svt-ech-retard" : "")">
                                            <td>@e.Libelle</td>
                                            <td class="svt-ech-num">@Fmt(e.Montant)</td>
                                            <td class="svt-ech-num">@Fmt(e.MontantPaye)</td>
                                            <td><span class="svt-ech-statut @ClasseStatut(e.Statut)">@AfficherStatut(e.Statut)</span></td>
                                            <td class="svt-ech-num">@Fmt(e.Reste)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>

            @* --- Détail des versements : meme largeur et meme position que la zone bleue
                   (colonne vide a gauche = gabarit du bloc synthese, slot vide a droite). --- *@
            <div class="svt-zone svt-zone-bas">
                @* Zone vide sous « Point de l'élève » : accueille l'assistante Sophia
                   (bulle ancrée ici, plus flottante par-dessus le menu). *@
                <div class="svt-resume-spacer svt-chat-host">
                    <ChatWidget Anchored="true" />
                </div>
                <div class="svt-detail-col">
                    <div class="svt-detail-titre">Détail des versements</div>
                    <div class="svt-detail acc-grid">
                <MudTable Items="_versements" Dense="true" Hover="true" Bordered="true">
                    <HeaderContent>
                        <MudTh Style="text-align:right; width:110px;">MONTANT</MudTh>
                        <MudTh Style="width:100px;">Date</MudTh>
                        <MudTh Style="width:88px;">Mode paiement</MudTh>
                        <MudTh Style="width:96px;">Nature versement</MudTh>
                        <MudTh Style="width:80px;">Statut élève</MudTh>
                        <MudTh Style="width:84px;">Ref Opération</MudTh>
                        <MudTh Style="width:78px; text-align:center;">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd Style="text-align:right; font-weight:600;">@Fmt(context.Montant)</MudTd>
                        <MudTd>@context.DateVersement.ToString("dd/MM/yyyy")</MudTd>
                        <MudTd>@context.MoyenPaiement</MudTd>
                        <MudTd>@context.Nature</MudTd>
                        @* Statut de l'ELEVE (Aff/Naff) — sert au futur point global « Total
                           payé par statut élève », pas le statut technique du versement. *@
                        <MudTd>@_sel?.Statut</MudTd>
                        <MudTd>@(context.ReferencePaiement == "-" ? "" : context.ReferencePaiement)</MudTd>
                        <MudTd Style="text-align:center; white-space:nowrap;">
                            <MudTooltip Text="Modifier ce versement">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               Color="Color.Primary" Disabled="_vEnCours"
                                               OnClick="@(() => EditerVersement(context))" />
                            </MudTooltip>
                            <MudTooltip Text="Supprimer définitivement ce versement">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error" Disabled="_vEnCours"
                                               OnClick="@(() => SupprimerVersementAsync(context))" />
                            </MudTooltip>
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Class="pa-2">Aucun versement pour cet élève.</MudText>
                    </NoRecordsContent>
                </MudTable>
                    </div>
                </div>
                <div class="svt-echeancier-slot"></div>
            </div>

            @* ============ Réductions accordées à l'élève ============
               Placé sous « Détail des versements ». La réduction s'impute sur les mensualités
               de scolarité EN PARTANT DE LA FIN, puis déborde sur l'inscription en dernier
               (mécanique backend). On saisit un type + un montant fixe OU un pourcentage. *@
            <div class="svt-reduc-zone">
                <div class="svt-reduc-titre">Réductions</div>
                <div class="svt-reduc-body">
                    <div class="svt-reduc-saisie">
                        <label>Type :</label>
                        <MudSelect T="string" @bind-Value="_rType" Dense="true"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Class="svt-reduc-type">
                            @foreach (var t in _typesReduction)
                            {
                                <MudSelectItem Value="@t.Libelle">@t.Libelle</MudSelectItem>
                            }
                        </MudSelect>
                        <label>Montant :</label>
                        <MudNumericField T="decimal" @bind-Value="_rMontant" HideSpinButtons="true" Min="0"
                                         Format="#,0" Culture="@_fr"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Class="svt-reduc-montant" />
                        <label>ou %&nbsp;:</label>
                        <MudNumericField T="decimal" @bind-Value="_rPourcent" HideSpinButtons="true" Min="0" Max="100"
                                         Format="0.##" Culture="@_fr"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" Class="svt-reduc-pct" />
                        <label>Réf. :</label>
                        <MudTextField T="string" @bind-Value="_rReference" Placeholder="N° arrêté, nom membre…"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" Class="svt-reduc-ref" />
                        <MudButton OnClick="AccorderReductionAsync" Variant="Variant.Filled" Color="Color.Primary"
                                   Size="Size.Small" Disabled="_rEnCours" Class="svt-reduc-btn"
                                   StartIcon="@Icons.Material.Filled.Discount">Accorder</MudButton>
                    </div>

                    <div class="svt-reduc-grid">
                        @if (_reductions.Count == 0)
                        {
                            <div class="svt-reduc-vide">Aucune réduction accordée.</div>
                        }
                        else
                        {
                            <table class="svt-reduc-table">
                                <thead>
                                    <tr><th>Type</th><th>Montant</th><th>%</th><th>Référence</th><th>Date</th><th></th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in _reductions)
                                    {
                                        <tr>
                                            <td>@r.Motif</td>
                                            <td class="svt-reduc-num">@Fmt(r.Montant)</td>
                                            <td class="svt-reduc-num">@(r.Pourcentage is null ? "" : r.Pourcentage.Value.ToString("0.##", _fr) + " %")</td>
                                            <td>@r.Reference</td>
                                            <td>@r.Date.ToString("dd/MM/yyyy")</td>
                                            <td class="svt-reduc-act">
                                                <MudTooltip Text="Annuler cette réduction">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                   Color="Color.Error" Disabled="_rEnCours"
                                                                   OnClick="@(() => SupprimerReductionAsync(r))" />
                                                </MudTooltip>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</MudPaper>

@* ==================== Aperçu avant impression du REÇU DE PAIEMENT ====================
   Même mécanisme que les listes (skill EnteteDeListe) : overlay HTML pur, seule « .recu-feuille »
   est conservée à l'impression (classe body « svt-print-recu », cf wwwroot/index.html). *@
@if (_recuApercuOuvert && _sel is not null)
{
    <div class="recu-overlay" @onclick="FermerRecuApercu">
        <div class="recu-panel" @onclick:stopPropagation="true">
            <div class="recu-toolbar">
                <span class="recu-toolbar-titre">Aperçu — Reçu de paiement</span>
                <div class="d-flex align-center gap-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Print"
                               OnClick="ImprimerRecuAsync">Imprimer</MudButton>
                    <MudButton Variant="Variant.Outlined" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Close"
                               OnClick="FermerRecuApercu">Fermer</MudButton>
                </div>
            </div>

            <div class="recu-feuille">
                @* En-tête officiel commun (calque EnteteDeListe). *@
                <div class="recu-entete">
                    <div class="recu-ministere">
                        <div class="recu-min-titre">RÉPUBLIQUE DE CÔTE D'IVOIRE</div>
                        <div class="recu-dren">MENA-DREN : <b>@_villeEcole</b></div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_logoEcole))
                    {
                        <div class="recu-logo"><img src="@_logoEcole" alt="Logo" /></div>
                    }
                    <div class="recu-ecole-droite">
                        <div class="recu-nom">@(string.IsNullOrWhiteSpace(_nomEcole) ? "ÉCOLE / ÉTABLISSEMENT" : _nomEcole)</div>
                        <div class="recu-annee">Année scolaire : @_annee</div>
                    </div>
                </div>

                <div class="recu-barre">
                    <div class="recu-titre">REÇU DE PAIEMENT</div>
                    <div class="recu-date">Édité le : @DateTime.Now.ToString("dd/MM/yyyy")</div>
                </div>

                @* Identité de l'élève. *@
                <div class="recu-eleve">
                    <div class="recu-champ"><span>Élève</span><b>@_sel.Nom @_sel.Prenoms</b></div>
                    <div class="recu-champ"><span>Matricule</span><b>@FormatMatricule(_sel.Matricule)</b></div>
                    <div class="recu-champ"><span>N° Inscr.</span><b>@_sel.NumOrdre</b></div>
                    <div class="recu-champ"><span>Classe</span><b>@FormatClasse(_sel.Classe)</b></div>
                </div>

                @* Versements enregistrés. *@
                <div class="recu-section-titre">Versements</div>
                <table class="recu-table">
                    <thead>
                        <tr>
                            <th class="r-num">N°</th>
                            <th>Date</th>
                            <th>Nature</th>
                            <th>Mode</th>
                            <th>Référence</th>
                            <th class="r-montant">Montant</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var vr = 0; }
                        @foreach (var v in _versements)
                        {
                            vr++;
                            <tr>
                                <td class="r-num">@vr</td>
                                <td>@v.DateVersement.ToString("dd/MM/yyyy")</td>
                                <td>@v.Nature</td>
                                <td>@v.MoyenPaiement</td>
                                <td>@v.ReferencePaiement</td>
                                <td class="r-montant">@Fmt(v.Montant)</td>
                            </tr>
                        }
                        @if (_versements.Count == 0)
                        {
                            <tr><td colspan="6" class="recu-vide">Aucun versement enregistré.</td></tr>
                        }
                    </tbody>
                </table>

                @* Synthèse du compte. *@
                @if (_resume is not null)
                {
                    <div class="recu-synthese">
                        <div><span>Frais de scolarité</span><b>@Fmt(_resume.FraisScolarite)</b></div>
                        @if (_resume.TotalReduction > 0)
                        {
                            <div><span>Réductions</span><b>- @Fmt(_resume.TotalReduction)</b></div>
                        }
                        <div><span>Total versé</span><b>@Fmt(_resume.TotalVerse)</b></div>
                        <div class="recu-synthese-reste"><span>Reste à payer</span><b>@Fmt(_resume.Reste)</b></div>
                        @if (_resume.Credit > 0)
                        {
                            <div><span>Crédit (avance)</span><b>@Fmt(_resume.Credit)</b></div>
                        }
                    </div>
                }

                @* Échéancier individuel. *@
                @if (_echeancier.Count > 0)
                {
                    <div class="recu-section-titre">Échéancier</div>
                    <table class="recu-table">
                        <thead>
                            <tr>
                                <th>Échéance</th>
                                <th class="r-montant">Montant</th>
                                <th class="r-montant">Payé</th>
                                <th class="r-montant">Reste</th>
                                <th>Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in _echeancier)
                            {
                                <tr>
                                    <td>@e.Libelle</td>
                                    <td class="r-montant">@Fmt(e.Montant)</td>
                                    <td class="r-montant">@Fmt(e.MontantPaye)</td>
                                    <td class="r-montant">@Fmt(e.Reste)</td>
                                    <td class="@(e.EnRetard && e.Statut != "Payé" ? "recu-retard" : "")">@e.Statut@(e.EnRetard && e.Statut != "Payé" ? " (retard)" : "")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                <div class="recu-signature">
                    <div>Le Comptable / la Caisse</div>
                    <div class="recu-signature-ligne">Signature &amp; cachet</div>
                </div>
            </div>
        </div>
    </div>
}
