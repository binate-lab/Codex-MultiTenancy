@page "/"
@using MudBlazor
@using TrajanEcole.Shared.Library.Models.Responses.Schools

<MudContainer MaxWidth="MaxWidth.False" Class="px-0">
    <!-- ---------- ECOLES ---------- -->
    <MudContainer MaxWidth="MaxWidth.Large" Class="py-1">

        <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">
            Trajan: <span class="font-weight-bold text-success">Tranquilité&nbsp;Et&nbsp;Souplesse</span>
        </MudText>

        @if (_isLoading)
        {
            <div class="d-flex justify-center my-8">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (_schools.Count == 0)
        {
            <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="my-8 mud-text-secondary">
                Aucune école pour le moment. Créez-en une depuis le menu « Écoles ».
            </MudText>
        }
        else
        {
            <!-- 3-up on desktop, 2-up on tablet, 1-up on mobile -->
            <MudGrid Spacing="3" Class="mt-4">
                @foreach (var school in _schools)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="3" Class="h-100">
                            <div @onclick="@(() => SelectSchoolAsync(school))"
                                 class="school-card-hover"
                                 style="cursor: pointer; height: 100%;">
                            <MudCardContent Class="d-flex flex-column align-center text-center pa-5">

                                @if (!string.IsNullOrWhiteSpace(school.Logo))
                                {
                                    <MudImage Src="@school.Logo"
                                              Style="width: 64px; height: 64px; object-fit: contain;" />
                                }
                                else
                                {
                                    <MudAvatar Color="Color.Primary" Size="Size.Large">
                                        @GetInitials(school)
                                    </MudAvatar>
                                }

                                <MudText Typo="Typo.h6" Class="mt-3 mb-1">
                                    @school.Name
                                </MudText>

                                @if (!string.IsNullOrWhiteSpace(school.Devise))
                                {
                                    <MudText Typo="Typo.body2">
                                        @school.Devise
                                    </MudText>
                                }
                            </MudCardContent>
                            </div>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudContainer>

</MudContainer>

@code {
    private bool _isLoading = true;
    private bool _selecting;
    private List<SchoolResponse> _schools = [];

    protected override async Task OnInitializedAsync()
    {
        // Écoles de l'utilisateur connecté uniquement (Admin tenant-wide => toutes).
        var result = await _schoolService.GetMineAsync();
        if (result.IsSuccessful && result.Data is not null)
        {
            _schools = result.Data;
        }
        // En l'absence d'école associée : liste vide => état vide affiché, sans erreur bloquante.

        _isLoading = false;
    }

    private async Task SelectSchoolAsync(SchoolResponse school)
    {
        if (_selecting)
        {
            return;
        }

        _selecting = true;
        try
        {
            // Échange le JWT courant contre un JWT école-scoped (claim school = CodeEts),
            // puis ouvre la page d'accueil de l'école sélectionnée.
            var result = await _tokenService.SelectSchoolAsync(school.CodeEts);
            if (result.IsSuccessful)
            {
                _navigation.NavigateTo("/ecole");
            }
            else
            {
                foreach (var message in result.Messages)
                {
                    _snackbar.Add(message, Severity.Error);
                }
            }
        }
        finally
        {
            _selecting = false;
        }
    }

    private static string GetInitials(SchoolResponse school)
    {
        var source = !string.IsNullOrWhiteSpace(school.NomCourtEts) ? school.NomCourtEts : school.Name;
        if (string.IsNullOrWhiteSpace(source))
        {
            return "?";
        }

        var parts = source.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            return string.Concat(parts[0][0], parts[1][0]).ToUpperInvariant();
        }

        var trimmed = source.Trim();
        return trimmed[..Math.Min(2, trimmed.Length)].ToUpperInvariant();
    }
}
