@page "/fne"
@layout SchoolLayout

<MudPaper Elevation="6" Class="ma-2">
    <MudToolBar Dense="true" Class="px-3" Style="background-color:#1b5e20; color:white;">
        <MudIcon Icon="@Icons.Material.Outlined.ReceiptLong" Class="mr-2" />
        <MudText Typo="Typo.h6">Facture Normalisée Électronique (FNE)</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Inherit"
                   OnClick="Fermer">Fermer</MudButton>
    </MudToolBar>

    <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true" PanelClass="pa-4">

        @* ------------------- Onglet 1 : paramètres DGI de l'école ------------------- *@
        <MudTabPanel Text="Paramètres" Icon="@Icons.Material.Outlined.Settings">
            <div style="max-width:760px;">
                <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary">
                    Identifiants déclarés auprès de la <b>DGI</b> pour la certification des factures.
                    Tant qu'ils ne sont pas renseignés (et le paramétrage <b>actif</b>), les factures
                    des versements validés restent <b>en attente</b> — aucune n'est perdue.
                </MudText>

                @if (_parametresCharges)
                {
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_parametres.Ncc" Label="NCC de l'école" Required="true"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="_enCours" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_parametres.PointOfSale" Label="Point de vente (pointOfSale)"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="_enCours" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudSelect T="string" @bind-Value="_parametres.Template" Label="Template"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="_enCours">
                                <MudSelectItem Value="@("B2C")">B2C — parents (particuliers)</MudSelectItem>
                                <MudSelectItem Value="@("B2B")">B2B — entreprise (NCC client)</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="8">
                            <MudTextField @bind-Value="_parametres.Establishment" Label="Établissement (establishment)"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="_enCours" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_parametres.TaxeParDefaut" Label="Code taxe (vide = exonéré)"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="_enCours" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_parametres.CommercialMessage" Label="Message commercial"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="_enCours" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_parametres.Footer" Label="Pied de facture"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Disabled="_enCours" />
                        </MudItem>
                        <MudItem xs="12" Class="d-flex align-center gap-4">
                            <MudSwitch T="bool" @bind-Value="_parametres.Actif" Color="Color.Success"
                                       Label="Certification active" Disabled="_enCours" />
                            <MudSpacer />
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_enCours"
                                       StartIcon="@Icons.Material.Filled.Save"
                                       OnClick="EnregistrerParametresAsync">Enregistrer</MudButton>
                        </MudItem>
                    </MudGrid>
                }
                else
                {
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                }
            </div>
        </MudTabPanel>

        @* ------------------- Onglet 2 : suivi des factures ------------------- *@
        <MudTabPanel Text="Suivi des factures" Icon="@Icons.Material.Outlined.FactCheck">
            <div class="d-flex align-center gap-2 mb-3" style="max-width:640px;">
                <MudSelect T="string" @bind-Value="_filtreStatut" Label="Statut" Clearable="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true"
                           Style="max-width:220px;">
                    <MudSelectItem T="string" Value="@(null)">(Tous)</MudSelectItem>
                    <MudSelectItem Value="@("EnAttente")">En attente</MudSelectItem>
                    <MudSelectItem Value="@("Certifiee")">Certifiée</MudSelectItem>
                    <MudSelectItem Value="@("Echec")">Échec</MudSelectItem>
                </MudSelect>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="_enCours"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           OnClick="ChargerFacturesAsync">Actualiser</MudButton>
                <MudSpacer />
                <MudChip T="string" Size="Size.Small" Color="Color.Default">@_factures.Count facture(s)</MudChip>
            </div>

            <MudTable Items="_factures" Dense="true" Hover="true" Bordered="true" Striped="true"
                      Loading="_enCours" RowsPerPage="25">
                <HeaderContent>
                    <MudTh>Date</MudTh>
                    <MudTh>Type</MudTh>
                    <MudTh>Statut</MudTh>
                    <MudTh>Référence DGI</MudTh>
                    <MudTh>Certifiée le</MudTh>
                    <MudTh Style="width:80px; text-align:center;">Essais</MudTh>
                    <MudTh>Erreur</MudTh>
                    <MudTh Style="width:70px; text-align:center;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">@context.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
                    <MudTd DataLabel="Type">@(context.TypeFacture == "refund" ? "Avoir" : "Vente")</MudTd>
                    <MudTd DataLabel="Statut">
                        <MudChip T="string" Size="Size.Small" Color="@CouleurStatut(context.Statut)">
                            @LibelleStatut(context.Statut)
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Référence DGI">
                        <span style="font-family:monospace;">@(context.Reference ?? "—")</span>
                    </MudTd>
                    <MudTd DataLabel="Certifiée le">
                        @(context.DateCertification?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—")
                    </MudTd>
                    <MudTd DataLabel="Essais" Style="text-align:center;">@context.Tentatives</MudTd>
                    <MudTd DataLabel="Erreur">
                        @if (!string.IsNullOrEmpty(context.Erreur))
                        {
                            <MudTooltip Text="@context.Erreur">
                                <span style="color:#c62828;">@Tronquer(context.Erreur)</span>
                            </MudTooltip>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align:center;">
                        <MudTooltip Text="Relancer la certification">
                            <MudIconButton Icon="@Icons.Material.Filled.Replay" Size="Size.Small"
                                           Color="Color.Warning"
                                           Disabled="@(_enCours || context.Statut == "Certifiee")"
                                           OnClick="@(() => RelancerAsync(context))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Class="pa-2">Aucune facture pour ce filtre.</MudText>
                </NoRecordsContent>
                <PagerContent>
                    <MudTablePager RowsPerPageString="Lignes :" InfoFormat="{first_item}-{last_item} sur {all_items}" />
                </PagerContent>
            </MudTable>
        </MudTabPanel>
    </MudTabs>
</MudPaper>
