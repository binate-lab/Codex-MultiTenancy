@page "/schools"

@using TrajanEcole.Shared.Library.Constants

@attribute [ShouldHavePermission(SchoolAction.Read, SchoolFeature.Schools)]

<Header OnReturn="Cancel" Title="Ecoles" Description="Gestion des Ecoles" />

<MudTable Items="@_schoolList"
          Loading="_isLoading"
          LoadingProgressColor="Color.Info"
          Elevation="25">
    <ToolBarContent>
        @if (_canCreateSchools)
        {
            <MudFab StartIcon="@Icons.Material.Filled.Add"
                    OnClick="OnBoardNewSchoolAsync"
                    Size="Size.Small"
                    IconSize="Size.Medium"
                    Class="mr-2" />
        }
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Code Ets</MudTh>
        <MudTh>Nom Court</MudTh>
        <MudTh>Nom</MudTh>
        <MudTh>Ville</MudTh>
        <MudTh>Statut</MudTh>
        <MudTh>Email</MudTh>
        <MudTh>Date de création</MudTh>
        <MudTh Style="text-align:right">Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Code Ets">@context.CodeEts</MudTd>
        <MudTd DataLabel="Nom Court">@context.NomCourtEts</MudTd>
        <MudTd DataLabel="Nom">@context.Name</MudTd>
        <MudTd DataLabel="Ville">@context.Ville</MudTd>
        <MudTd DataLabel="Statut">
            <MudChip T="string"
                     Color="@(context.Statut == StatutEcole.Public ? Color.Info : Color.Warning)"
                     Size="Size.Small">
                @(context.Statut == StatutEcole.Public ? "Public" : "Privé")
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Email">@context.Email</MudTd>
        <MudTd DataLabel="Date création">@context.EstablishedDate.ToString("dd MMM yyyy")</MudTd>
        <MudTd Style="text-align:right" DataLabel="Actions">
            <MudMenu Icon="@Icons.Material.Filled.MoreVert"
                     Size="Size.Small"
                     Color="Color.Secondary"
                     TransformOrigin="Origin.BottomLeft"
                     AnchorOrigin="Origin.BottomLeft">
                @if (_canUpdateSchools)
                {
                    <MudMenuItem OnClick="@(() => UpdateSchoolAsync(context))">Mise à jour</MudMenuItem>
                }
                @if (_canDeleteSchools)
                {
                    <MudMenuItem OnClick="@(() => DeleteSchoolAsync(context))" Style="color: var(--mud-palette-error);">Supprimer</MudMenuItem>
                }
            </MudMenu>
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager RowsPerPageString="LignesParPage" InfoFormat="{first_item}-{last_item} sur {all_items}" />
    </PagerContent>
</MudTable>
