<MudForm @ref="_form" Model="UpdateSchoolRequest" Validation="@(_validator.ValidateValue)" ValidationDelay="0">
    <MudDialog>
        <TitleContent>
            <MudText>
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-3 mb-n1" />
                Modifier l'école
            </MudText>
        </TitleContent>
        <DialogContent>
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="UpdateSchoolRequest.CodeEts"
                                  For="@(() => UpdateSchoolRequest.CodeEts)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Label="Code Ets" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="UpdateSchoolRequest.NomCourtEts"
                                  For="@(() => UpdateSchoolRequest.NomCourtEts)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Label="Nom Court (11 car. max)" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="UpdateSchoolRequest.Name"
                                  For="@(() => UpdateSchoolRequest.Name)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Label="Nom Ecole" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="UpdateSchoolRequest.Email"
                                  For="@(() => UpdateSchoolRequest.Email)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Label="Email" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="UpdateSchoolRequest.Telephone"
                                  For="@(() => UpdateSchoolRequest.Telephone)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Label="Téléphone" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="UpdateSchoolRequest.Ville"
                                  For="@(() => UpdateSchoolRequest.Ville)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Label="Ville" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="UpdateSchoolRequest.Statut"
                               For="@(() => UpdateSchoolRequest.Statut)"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Label="Statut">
                        <MudSelectItem Value="@(StatutEcole.Public)">Public</MudSelectItem>
                        <MudSelectItem Value="@(StatutEcole.Prive)">Privé</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudDatePicker Context="PickerContext"
                                   @bind-Date="EstablishedDatePicker"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   @ref="_datePicker"
                                   Label="Date Création" />
                </MudItem>
                <MudItem xs="12" md="8">
                    <MudTextField @bind-Value="UpdateSchoolRequest.Logo"
                                  For="@(() => UpdateSchoolRequest.Logo)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Label="Logo (URL ou /images/...)" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="UpdateSchoolRequest.Devise"
                                  For="@(() => UpdateSchoolRequest.Devise)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Label="Devise" />
                </MudItem>
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CancelDialog" Variant="Variant.Outlined" Class="mr-auto">Annuler</MudButton>
            <MudButton OnClick="SubmitAsync" Variant="Variant.Outlined" Color="Color.Primary"
                Disabled="@(!_validator.Validate(UpdateSchoolRequest).IsValid)">Enregistrer</MudButton>
        </DialogActions>
    </MudDialog>
</MudForm>
