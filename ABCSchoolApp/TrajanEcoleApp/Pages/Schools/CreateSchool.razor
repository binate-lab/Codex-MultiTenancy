<MudForm @ref="_form" Model="CreateSchoolRequest" Validation="@(_validator.ValidateValue)" ValidationDelay="0">
    <MudDialog>
        <TitleContent>
            <MudText>
                <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-3 mb-n1" />
                Ajouter une nouvelle école
            </MudText>
        </TitleContent>
        <DialogContent>
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="CreateSchoolRequest.CodeEts"
                                  For="@(() => CreateSchoolRequest.CodeEts)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Label="Code Ets" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="CreateSchoolRequest.NomCourtEts"
                                  For="@(() => CreateSchoolRequest.NomCourtEts)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Label="Nom Court (11 car. max)" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="CreateSchoolRequest.Name"
                                  For="@(() => CreateSchoolRequest.Name)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Label="Nom Ecole" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="CreateSchoolRequest.Email"
                                  For="@(() => CreateSchoolRequest.Email)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Label="Email" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="CreateSchoolRequest.Telephone"
                                  For="@(() => CreateSchoolRequest.Telephone)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Label="Téléphone" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="CreateSchoolRequest.Ville"
                                  For="@(() => CreateSchoolRequest.Ville)"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Label="Ville" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="CreateSchoolRequest.Statut"
                               For="@(() => CreateSchoolRequest.Statut)"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Label="Statut">
                        <MudSelectItem Value="@(StatutEcole.Public)">Public</MudSelectItem>
                        <MudSelectItem Value="@(StatutEcole.Prive)">Privé</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudDatePicker Context="PickerContext"
                                   @bind-Date="EstablishedDatePicker"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   @ref="_datePicker"
                                   Label="Date Création" />
                </MudItem>
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CancelDialog" Variant="Variant.Outlined" Class="mr-auto">Annuler</MudButton>
            <MudButton OnClick="SubmitAsync" Variant="Variant.Outlined" Color="Color.Primary"
                Disabled="@(!_validator.Validate(CreateSchoolRequest).IsValid)">Enregistrer</MudButton>
        </DialogActions>
    </MudDialog>
</MudForm>
