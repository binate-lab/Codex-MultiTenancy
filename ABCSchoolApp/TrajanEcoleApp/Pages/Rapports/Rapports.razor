@page "/rapports"
@layout SchoolLayout
@using System.Globalization
@using global::App.Infrastructure.Services.Rapports
@inject IRapportService _rapportService
@inject IJSRuntime _js

<MudPaper Elevation="6" Class="ma-2">
    <div class="acc-window">

        <!-- Bandeau : titre + année + Fermer (même patron que /scolarites) -->
        <div class="acc-titlebar">
            <div class="d-flex align-center gap-3">
                <span class="acc-title">Rapports — Économat</span>
                <span class="acc-year">@_annee</span>
            </div>
            <div class="d-flex align-center gap-2">
                <MudButton Variant="Variant.Text" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Close"
                           OnClick="@(() => _navigation.NavigateTo("/ecole"))">Fermer</MudButton>
            </div>
        </div>

        <div class="pa-4">
            <MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">
                Choisis un rapport, règle la période, puis génère le PDF (avec l'en-tête
                officiel de l'école).
            </MudText>

            <!-- ============ Famille : Versements ============ -->
            <MudText Typo="Typo.subtitle1" Class="rpt-famille">Versements</MudText>
            <div class="rpt-cartes">
                <div class="rpt-carte @(_selected == RapportId.ParEleve ? "rpt-carte-active" : "")"
                     @onclick="@(() => Selectionner(RapportId.ParEleve))">
                    <MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Primary" Size="Size.Large" />
                    <div class="rpt-carte-titre">Par élève</div>
                    <div class="rpt-carte-desc">Un élève par ligne, groupé par niveau (montant, dû, payé, reste).</div>
                </div>

                <div class="rpt-carte @(_selected == RapportId.ParClasse ? "rpt-carte-active" : "")"
                     @onclick="@(() => Selectionner(RapportId.ParClasse))">
                    <MudIcon Icon="@Icons.Material.Filled.TableChart" Color="Color.Secondary" Size="Size.Large" />
                    <div class="rpt-carte-titre">Par classe</div>
                    <div class="rpt-carte-desc">Point au jour (sans période) : synthèse par classe + totaux et taux de recouvrement (camembert).</div>
                </div>

                <div class="rpt-carte @(_selected == RapportId.Recouvrement ? "rpt-carte-active" : "")"
                     @onclick="@(() => Selectionner(RapportId.Recouvrement))">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Color="Color.Warning" Size="Size.Large" />
                    <div class="rpt-carte-titre">Recouvrement</div>
                    <div class="rpt-carte-desc">Point au jour : ce qui devait être recouvré (échéances échues) face à ce qui l'a été, par classe.</div>
                </div>

                <div class="rpt-carte @(_selected == RapportId.ParNature ? "rpt-carte-active" : "")"
                     @onclick="@(() => Selectionner(RapportId.ParNature))">
                    <MudIcon Icon="@Icons.Material.Filled.Category" Color="Color.Tertiary" Size="Size.Large" />
                    <div class="rpt-carte-titre">Par nature</div>
                    <div class="rpt-carte-desc">Bilan des encaissements par nature (Arriéré, Inscription, Scolarité…), ventilé Général / AFF / NAFF.</div>
                </div>

                <div class="rpt-carte @(_selected == RapportId.ParModePaiement ? "rpt-carte-active" : "")"
                     @onclick="@(() => Selectionner(RapportId.ParModePaiement))">
                    <MudIcon Icon="@Icons.Material.Filled.CreditCard" Color="Color.Info" Size="Size.Large" />
                    <div class="rpt-carte-titre">Par mode de paiement</div>
                    <div class="rpt-carte-desc">Bilan des encaissements par moyen de paiement (Espèce, Chèque, Virement, Mobile Money…) avec la part de chacun.</div>
                </div>
            </div>

            <!-- ============ Familles à venir (extensible) ============ -->
            <MudText Typo="Typo.subtitle1" Class="rpt-famille">Autres familles (à venir)</MudText>
            <div class="rpt-cartes">
                <div class="rpt-carte rpt-carte-disabled">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Size="Size.Large" />
                    <div class="rpt-carte-titre">Effectifs</div>
                    <div class="rpt-carte-desc">Par niveau, par sexe…</div>
                </div>
                <div class="rpt-carte rpt-carte-disabled">
                    <MudIcon Icon="@Icons.Material.Filled.PointOfSale" Size="Size.Large" />
                    <div class="rpt-carte-titre">Caisse</div>
                    <div class="rpt-carte-desc">Arrêté de caisse, journal…</div>
                </div>
            </div>

            <!-- ============ Panneau de configuration du rapport choisi ============ -->
            @if (_selected is not null)
            {
                <MudPaper Elevation="2" Class="rpt-config mt-4 pa-4">
                    <MudText Typo="Typo.subtitle1" Class="mb-3">
                        <b>@TitreRapport(_selected.Value)</b> — @(SansPeriode ? "point au jour" : "période")
                    </MudText>

                    <div class="d-flex align-end gap-4 flex-wrap mb-4">
                        @if (!SansPeriode)
                        {
                            <MudDatePicker Label="Du" @bind-Date="_debut" DateFormat="dd/MM/yyyy"
                                           Editable="true" ImmediateText="true"
                                           Culture="@_fr" Variant="Variant.Outlined" Margin="Margin.Dense"
                                           Style="max-width: 190px;" />
                            <MudDatePicker Label="Au" @bind-Date="_fin" DateFormat="dd/MM/yyyy"
                                           Editable="true" ImmediateText="true"
                                           Culture="@_fr" Variant="Variant.Outlined" Margin="Margin.Dense"
                                           Style="max-width: 190px;" />
                        }
                        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.PictureAsPdf"
                                   Disabled="_enCours" OnClick="GenererAsync">
                            Générer le PDF
                        </MudButton>
                    </div>

                    @if (_enCours)
                    {
                        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                    }
                </MudPaper>
            }
        </div>
    </div>
</MudPaper>

@code {
    private static readonly CultureInfo _fr = CultureInfo.GetCultureInfo("fr-FR");

    private enum RapportId { ParEleve, ParClasse, ParNature, ParModePaiement, Recouvrement }

    private RapportId? _selected;

    // Rapports « point au jour » : pas de periode a saisir (l'API ignore les dates).
    private bool SansPeriode => _selected is RapportId.ParClasse or RapportId.Recouvrement;

    private string _annee = "—";
    private string _nomEcole = string.Empty;
    private string _logoEcole = string.Empty;
    private string _villeEcole = string.Empty;

    private DateTime? _debut = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime? _fin = DateTime.Today;

    private bool _enCours;

    private void Selectionner(RapportId id)
    {
        _selected = id;

        // Les bilans de caisse (par nature, par mode de paiement) se font par defaut sur la
        // journee du jour (date1 = date2 = aujourd'hui) ; les autres rapports gardent la
        // periode « mois en cours ».
        if (id is RapportId.ParNature or RapportId.ParModePaiement)
        {
            _debut = DateTime.Today;
            _fin = DateTime.Today;
        }
    }

    private static string TitreRapport(RapportId id) => id switch
    {
        RapportId.ParEleve => "Versements par élève",
        RapportId.ParClasse => "Versements par classe",
        RapportId.ParNature => "Bilan par nature des versements",
        RapportId.ParModePaiement => "Bilan par mode de paiement",
        RapportId.Recouvrement => "Rapport de recouvrement",
        _ => string.Empty
    };

    protected override async Task OnInitializedAsync()
    {
        var annee = await _anneeScolaireService.GetAnneeEnCoursAsync();
        if (annee.IsSuccessful && annee.Data is not null)
            _annee = annee.Data.Libelle;

        var user = await _applicationStateProvider.GetAuthenticationStateProviderUserAsync();
        var codeEts = user.FindFirst("school")?.Value;
        if (!string.IsNullOrWhiteSpace(codeEts))
        {
            var ecoles = await _schoolService.GetMineAsync();
            if (ecoles.IsSuccessful && ecoles.Data is not null)
            {
                var ecole = ecoles.Data.FirstOrDefault(s => s.CodeEts == codeEts);
                _nomEcole = ecole?.Name ?? string.Empty;
                _logoEcole = ecole?.Logo ?? string.Empty;
                _villeEcole = ecole?.Ville ?? string.Empty;
            }
        }
    }

    private async Task GenererAsync()
    {
        if (_selected is null) return;

        if (!SansPeriode)
        {
            if (_debut is null || _fin is null)
            {
                _snackbar.Add("Renseigne la période (Du / Au).", Severity.Warning);
                return;
            }
            if (_debut > _fin)
            {
                _snackbar.Add("La date de début doit précéder la date de fin.", Severity.Warning);
                return;
            }
        }

        _enCours = true;
        try
        {
            var logoBase64 = string.IsNullOrWhiteSpace(_logoEcole)
                ? null
                : await _js.InvokeAsync<string>("trajanImageEnBase64", _logoEcole);

            var annee = _annee == "—" ? string.Empty : _annee;
            // Rapports sans periode : dates du jour (ignorees par l'API, contrat inchange).
            var debut = SansPeriode ? DateOnly.FromDateTime(DateTime.Today) : DateOnly.FromDateTime(_debut.Value);
            var fin = SansPeriode ? DateOnly.FromDateTime(DateTime.Today) : DateOnly.FromDateTime(_fin.Value);

            var (pdf, prefixe) = _selected.Value switch
            {
                RapportId.ParEleve => (
                    await _rapportService.GetRapportMensuelPdfAsync(debut, fin, _nomEcole, logoBase64, _villeEcole, annee),
                    "rapport-par-eleve"),
                RapportId.ParClasse => (
                    await _rapportService.GetRapportParClassePdfAsync(debut, fin, _nomEcole, logoBase64, _villeEcole, annee),
                    "rapport-par-classe"),
                RapportId.ParNature => (
                    await _rapportService.GetRapportParNaturePdfAsync(debut, fin, _nomEcole, logoBase64, _villeEcole, annee),
                    "bilan-par-nature"),
                RapportId.ParModePaiement => (
                    await _rapportService.GetRapportParModePaiementPdfAsync(debut, fin, _nomEcole, logoBase64, _villeEcole, annee),
                    "bilan-par-mode-paiement"),
                RapportId.Recouvrement => (
                    await _rapportService.GetRapportRecouvrementPdfAsync(_nomEcole, logoBase64, _villeEcole, annee),
                    "rapport-recouvrement"),
                _ => (null, "rapport")
            };

            if (pdf is null || pdf.Length == 0)
            {
                _snackbar.Add("Le rapport est vide pour cette période (aucun versement).", Severity.Warning);
                return;
            }

            var nomFichier = SansPeriode
                ? $"{prefixe}-{DateTime.Today:yyyyMMdd}.pdf"
                : $"{prefixe}-{debut:yyyyMMdd}-{fin:yyyyMMdd}.pdf";
            // Ouverture dans un ONGLET (lecteur PDF du navigateur) : affichage immediat,
            // et les gestionnaires de telechargement (IDM...) ne s'en melent pas.
            await _js.InvokeVoidAsync("trajanOuvrirFichier",
                nomFichier, Convert.ToBase64String(pdf), "application/pdf");
        }
        catch (Exception ex)
        {
            // Message HONNETE : on affiche la vraie cause (HTTP 401, contenu mixte, CORS…)
            // au lieu d'un « indisponible » trompeur. Detail complet dans la console (F12).
            _snackbar.Add($"Échec de génération : {ex.Message}", Severity.Error);
            Console.Error.WriteLine($"[Rapport {_selected}] {ex}");
        }
        finally
        {
            _enCours = false;
        }
    }
}
