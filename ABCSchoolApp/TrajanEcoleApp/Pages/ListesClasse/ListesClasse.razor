@page "/listes-classe"
@layout SchoolLayout

<MudPaper Elevation="6" Class="ma-2">
    <div class="acc-window">

        <!-- Bandeau : titre + année + Fermer -->
        <div class="acc-titlebar">
            <div class="d-flex align-center gap-3">
                <span class="acc-title">Liste de classe</span>
                <span class="acc-year">@_annee</span>
            </div>
            <div class="d-flex align-center gap-2">
                <MudButton Variant="Variant.Text" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Autorenew"
                           OnClick="RegenererClesAsync">Corriger clés</MudButton>
                <MudButton Variant="Variant.Text" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Print"
                           OnClick="OuvrirApercu">Imprimer</MudButton>
                <MudButton Variant="Variant.Text" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Close"
                           OnClick="Fermer">Fermer</MudButton>
            </div>
        </div>

        <!-- ============ Barre de filtres (cascade Cycle -> Niveau -> Classe) ============ -->
        <!-- lc-filtres : marqueur de page pour ramener la typo des filtres à la taille MudBlazor
             par défaut (comme Échéancier), sans tronquer — scopé pour ne pas toucher /scolarites. -->
        <div class="acc-filterbar lc-filtres">
            <div class="acc-fgroup">
                <label class="acc-flabel">Cycle :</label>
                <MudSelect Value="_fCycleId" ValueChanged="OnFiltreCycleChanged" T="string" Clearable="true" Dense="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-fnarrow">
                    <MudSelectItem Value="@("")">Tous</MudSelectItem>
                    @foreach (var c in _cycles)
                    {
                        <MudSelectItem Value="@c.Id.ToString()">@c.Numero</MudSelectItem>
                    }
                </MudSelect>
            </div>
            <div class="acc-fgroup">
                <label class="acc-flabel">Niveau :</label>
                @* Cascade : ne montre que les niveaux du cycle filtré (tous si aucun cycle). *@
                <MudSelect Value="_fNiveau" ValueChanged="OnFiltreNiveauChanged" T="string" Clearable="true" Dense="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-fnarrow lc-fniveau">
                    <MudSelectItem Value="@("")">Tous</MudSelectItem>
                    @foreach (var n in NiveauxFiltre)
                    {
                        <MudSelectItem Value="@n">@n</MudSelectItem>
                    }
                </MudSelect>
            </div>
            <div class="acc-fgroup">
                <label class="acc-flabel">Classe :</label>
                @* Cascade : classes du niveau filtré, sinon du cycle filtré, sinon toutes. *@
                <MudSelect Value="_fClasse" ValueChanged="OnFiltreClasseChanged" T="string" Clearable="true" Dense="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-fnarrow acc-fclasse">
                    <MudSelectItem Value="@("")">Toutes</MudSelectItem>
                    @foreach (var cl in ClassesFiltre)
                    {
                        <MudSelectItem Value="@cl.Libelle">@cl.Libelle</MudSelectItem>
                    }
                </MudSelect>
            </div>
            <div class="acc-fgroup">
                <label class="acc-flabel">Statut :</label>
                <MudSelect Value="_fStatut" ValueChanged="OnFiltreStatutChanged" T="string" Dense="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-fnarrow">
                    <MudSelectItem Value="@("Tous")">Tous</MudSelectItem>
                    <MudSelectItem Value="@("Aff")">Aff</MudSelectItem>
                    <MudSelectItem Value="@("Naff")">Naff</MudSelectItem>
                </MudSelect>
            </div>
            <div class="acc-fgroup">
                <label class="acc-flabel">Sexe :</label>
                <MudSelect Value="_fSexe" ValueChanged="OnFiltreSexeChanged" T="string" Dense="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-fnarrow">
                    <MudSelectItem Value="@("Tous")">Tous</MudSelectItem>
                    <MudSelectItem Value="@("G")">Garçons</MudSelectItem>
                    <MudSelectItem Value="@("F")">Filles</MudSelectItem>
                </MudSelect>
            </div>
            <div class="acc-fgroup">
                <label class="acc-flabel">Inscrit :</label>
                <MudSelect Value="_fInscrit" ValueChanged="OnFiltreInscritChanged" T="string" Dense="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-fnarrow">
                    <MudSelectItem Value="@("Tous")">Tous</MudSelectItem>
                    <MudSelectItem Value="@("Oui")">Oui</MudSelectItem>
                    <MudSelectItem Value="@("Non")">Non</MudSelectItem>
                </MudSelect>
            </div>
            <div class="acc-fgroup">
                <label class="acc-flabel">Actif :</label>
                <MudSelect Value="_fActif" ValueChanged="OnFiltreActifChanged" T="string" Dense="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-fnarrow">
                    <MudSelectItem Value="@("Tous")">Tous</MudSelectItem>
                    <MudSelectItem Value="@("Oui")">Oui</MudSelectItem>
                    <MudSelectItem Value="@("Non")">Non</MudSelectItem>
                </MudSelect>
            </div>
            <MudButton OnClick="Effacer" Variant="Variant.Outlined" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.FilterAltOff" Class="ml-auto">Effacer</MudButton>

            @* Matricule + N° Inscr sur une 2e ligne pleine largeur (à gauche, en jaune).
               Conteneur unique => une seule row-gap (au lieu du double gap d'un séparateur). *@
            <div class="lc-row2">
                <div class="acc-fgroup">
                    <label class="acc-flabel">Matricule :</label>
                    <MudTextField Value="_fMatricule" ValueChanged="OnFiltreMatriculeChanged" T="string"
                                  Immediate="true" Clearable="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-yellow" />
                </div>
                <div class="acc-fgroup">
                    <label class="acc-flabel">N° Inscr. :</label>
                    <MudTextField Value="_fNumOrdre" ValueChanged="OnFiltreNumOrdreChanged" T="string"
                                  Immediate="true" Clearable="true" Placeholder="N°…"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Class="acc-ffield acc-fnarrow acc-yellow" />
                </div>
            </div>
        </div>

        <!-- ============ Grille (gauche) + Fiche Élève (droite), côte à côte ============ -->
        <div class="lc-layout">
        <div class="lc-grid-col">
        <!-- Le div wrapper porte le scope CSS (::deep) ET la classe .acc-grid-eleves ciblée
             par les règles globales (26px) et le handler clavier de wwwroot/index.html.
             La colonne étant bornée, la grille défile horizontalement (overflow-x). -->
        <div class="acc-grid acc-grid-eleves">
        <MudTable T="EleveRow" Items="Filtered" Dense="true" Hover="true" Bordered="true"
                  RowsPerPage="_rowsPerPage" RowsPerPageChanged="OnRowsPerPageChanged"
                  CurrentPage="_page" CurrentPageChanged="OnPageChanged"
                  OnRowClick="OnRowClick" RowClassFunc="LigneClass">
            @* Largeurs FIXES : indispensables au gel des 7 premières colonnes (table-layout:fixed
               + sticky left en CSS). Ne pas les changer sans ajuster les offsets left du .razor.css. *@
            <HeaderContent>
                <MudTh Style="width:60px; text-align:right">N° Inscr.</MudTh>
                <MudTh Style="width:116px">Matricule</MudTh>
                <MudTh Style="width:130px">Nom</MudTh>
                <MudTh Style="width:150px">Prénoms</MudTh>
                <MudTh Style="width:56px">Cycle</MudTh>
                <MudTh Style="width:72px">Niveau</MudTh>
                <MudTh Style="width:88px">Classe</MudTh>
                <MudTh Style="width:60px">Série</MudTh>
                <MudTh Style="width:64px">Red</MudTh>
                <MudTh Style="width:120px">LV2</MudTh>
                <MudTh Style="width:140px">Arts</MudTh>
                <MudTh Style="width:74px">Statut</MudTh>
                <MudTh Style="width:50px; text-align:center">Sexe</MudTh>
                <MudTh Style="width:92px">Date naiss.</MudTh>
                <MudTh Style="width:120px">Lieu naiss.</MudTh>
                <MudTh Style="width:96px">Nationalité</MudTh>
                <MudTh Style="width:110px">Tél.</MudTh>
                <MudTh Style="width:56px; text-align:center">Inscrit</MudTh>
                <MudTh Style="width:56px; text-align:center">Actif</MudTh>
                <MudTh Style="width:56px; text-align:center">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="N° Inscr." Style="text-align:right">@context.NumOrdre</MudTd>
                <MudTd DataLabel="Matricule" Class="acc-cell-matricule">@FormatMatricule(context.Matricule)</MudTd>
                <MudTd DataLabel="Nom" Class="acc-cell-nom">@context.Nom</MudTd>
                <MudTd DataLabel="Prénoms" Class="acc-cell-prenom">@context.Prenoms</MudTd>
                <MudTd DataLabel="Cycle" data-col="Cycle" data-eleve-id="@context.Id">
                    @* « Activer colonne=Cycle » : correction (toutes écoles, SANS cascade). Sinon,
                       édition publique avec cascade, ou lecture seule en privé. *@
                    @if (_colonneActive == "cycle")
                    {
                        <MudSelect T="int" Value="@context.Cycle"
                                   ValueChanged="@(v => OnCycleCorrige(context, v))"
                                   Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Underline="false"
                                   Class="acc-cell-select">
                            @foreach (var c in _cycles)
                            {
                                <MudSelectItem Value="@c.Numero">@c.Numero</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else if (_ecolePublique)
                    {
                        <MudSelect T="int" Value="@context.Cycle"
                                   ValueChanged="@(v => OnCycleChanged(context, v))"
                                   Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Underline="false"
                                   Class="acc-cell-select">
                            @foreach (var c in _cycles)
                            {
                                <MudSelectItem Value="@c.Numero">@c.Numero</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else
                    {
                        @context.Cycle
                    }
                </MudTd>
                <MudTd DataLabel="Niveau" data-col="Niveau" data-eleve-id="@context.Id">
                    @if (_ecolePublique)
                    {
                        @* Cascade : niveaux du cycle de la ligne. *@
                        <MudSelect T="string" Value="@context.Niveau"
                                   ValueChanged="@(v => OnNiveauChanged(context, v))"
                                   Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Underline="false"
                                   Class="acc-cell-select">
                            @foreach (var n in NiveauxDuCycleNumero(context.Cycle))
                            {
                                <MudSelectItem Value="@n">@n</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else
                    {
                        @context.Niveau
                    }
                </MudTd>
                <MudTd DataLabel="Classe" data-col="Classe" data-eleve-id="@context.Id">
                    @* Classe éditable : déroulante alimentée par le référentiel Structures
                       (classes du niveau de la ligne). *@
                    <MudSelect T="string" Value="@context.Classe"
                               ValueChanged="@(v => OnClasseChanged(context, v))"
                               Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Underline="false"
                               Class="acc-cell-select acc-cell-classe">
                        @foreach (var cl in ClassesPour(context.Niveau))
                        {
                            <MudSelectItem Value="@cl.Libelle">@cl.Libelle</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="Série">@context.Serie</MudTd>
                <MudTd DataLabel="Red" data-col="Red" data-eleve-id="@context.Id">
                    @* R / NR (redoublant) éditable pour toutes les écoles. *@
                    <MudSelect T="string" Value="@context.Red"
                               ValueChanged="@(v => OnRedChanged(context, v))"
                               Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Underline="false"
                               Clearable="true" Class="acc-cell-select">
                        <MudSelectItem Value="@("R")">R</MudSelectItem>
                        <MudSelectItem Value="@("NR")">NR</MudSelectItem>
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="LV2" data-col="LV_2" data-eleve-id="@context.Id">
                    @* LV2 éditable pour toutes les écoles (aucun impact échéancier) : Allemand / Espagnol. *@
                    <MudSelect T="string" Value="@context.LV_2"
                               ValueChanged="@(v => OnLv2Changed(context, v))"
                               Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Underline="false"
                               Clearable="true" Class="acc-cell-select">
                        <MudSelectItem Value="@("Allemand")">Allemand</MudSelectItem>
                        <MudSelectItem Value="@("Espagnol")">Espagnol</MudSelectItem>
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="Arts" data-col="Arts" data-eleve-id="@context.Id">
                    @* Arts éditable pour toutes les écoles : Arts Plastiques / Musique. *@
                    <MudSelect T="string" Value="@context.Arts"
                               ValueChanged="@(v => OnArtsChanged(context, v))"
                               Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Underline="false"
                               Clearable="true" Class="acc-cell-select">
                        <MudSelectItem Value="@("Arts Plastiques")">Arts Plastiques</MudSelectItem>
                        <MudSelectItem Value="@("Musique")">Musique</MudSelectItem>
                    </MudSelect>
                </MudTd>
                <MudTd DataLabel="Statut" data-col="Statut" data-eleve-id="@context.Id">
                    @if (_ecolePublique)
                    {
                        <MudSelect T="string" Value="@context.Statut"
                                   ValueChanged="@(v => OnStatutChanged(context, v))"
                                   Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Underline="false"
                                   Class="acc-cell-select">
                            <MudSelectItem Value="@("Aff")">Aff</MudSelectItem>
                            <MudSelectItem Value="@("Naff")">Naff</MudSelectItem>
                        </MudSelect>
                    }
                    else
                    {
                        @context.Statut
                    }
                </MudTd>
                <MudTd DataLabel="Sexe" Style="text-align:center">@context.Sexe</MudTd>
                <MudTd DataLabel="Date naiss.">
                    @if (_colonneActive == "datenaiss")
                    {
                        <MudDatePicker Date="@context.DateNaissance"
                                       DateChanged="@(d => OnDateNaissChanged(context, d))"
                                       DateFormat="dd/MM/yyyy" Editable="true"
                                       Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Underline="false"
                                       Class="acc-cell-select" />
                    }
                    else
                    {
                        @(context.DateNaissance?.ToString("dd/MM/yyyy"))
                    }
                </MudTd>
                <MudTd DataLabel="Lieu naiss.">
                    @if (_colonneActive == "lieunaiss")
                    {
                        <MudTextField T="string" Value="@context.LieuNaissance"
                                      ValueChanged="@((string v) => OnLieuNaissChanged(context, v))"
                                      Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Underline="false"
                                      Class="acc-cell-select" />
                    }
                    else
                    {
                        @context.LieuNaissance
                    }
                </MudTd>
                <MudTd DataLabel="Nationalité">
                    @if (_colonneActive == "nationalite")
                    {
                        <MudTextField T="string" Value="@context.Nationalite"
                                      ValueChanged="@((string v) => OnNationaliteChanged(context, v))"
                                      Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Underline="false"
                                      Class="acc-cell-select" />
                    }
                    else
                    {
                        @context.Nationalite
                    }
                </MudTd>
                <MudTd DataLabel="Tél.">
                    @if (_colonneActive == "telephone")
                    {
                        <MudTextField T="string" Value="@context.Telephone"
                                      ValueChanged="@((string v) => OnTelephoneChanged(context, v))"
                                      Dense="true" Margin="Margin.Dense" Variant="Variant.Text" Underline="false"
                                      Class="acc-cell-select" />
                    }
                    else
                    {
                        @context.Telephone
                    }
                </MudTd>
                <MudTd DataLabel="Inscrit" Style="text-align:center">
                    <MudIcon Size="Size.Small"
                             Icon="@(context.Inscrit ? Icons.Material.Filled.CheckBox : Icons.Material.Filled.CheckBoxOutlineBlank)" />
                </MudTd>
                <MudTd DataLabel="Actif" Style="text-align:center">
                    <MudIcon Size="Size.Small"
                             Icon="@(context.Actif ? Icons.Material.Filled.CheckBox : Icons.Material.Filled.CheckBoxOutlineBlank)" />
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align:center">
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true"
                             AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
                        <MudMenuItem Icon="@Icons.Material.Filled.Person" OnClick="@(() => VoirFiche(context))">Voir la fiche</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.MoveDown" OnClick="@(() => AllerClasse(context))">Changer de classe</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.Badge" OnClick="@(() => ImprimerFiche(context))">Imprimer Fiche Élève</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.Print" OnClick="OuvrirApercu">Imprimer la liste</MudMenuItem>
                    </MudMenu>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Class="pa-2">Aucun élève ne correspond au filtre.</MudText>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 10, 25, 50 }" RowsPerPageString="Lignes par page" />
            </PagerContent>
        </MudTable>
        </div>

        <div class="acc-gridfoot">
            <MudText Typo="Typo.caption">
                @Filtered.Count() élève(s) affiché(s) — Garçons : @GrilleGarcons · Filles : @GrilleFilles
            </MudText>
            <MudText Typo="Typo.caption" Class="acc-demo-note">
                Source : Pédagogie (PedagogieDb). Statut / Classe / Red / LV2 / Arts éditables (Ctrl+' = recopie du dessus).
            </MudText>
        </div>

        @* ============ Opérations en masse sur les élèves AFFICHÉS (filtrés) ============ *@
        <div class="lc-bulk">
            <span class="lc-bulk-label">Action en masse :</span>
            <MudSelect T="string" Value="_bulkOp" ValueChanged="OnBulkOpChanged" Clearable="true"
                       Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="lc-bulk-op"
                       Style="width:185px" Placeholder="Choisir…">
                <MudSelectItem Value="@("prenom-minuscule")">Minuscule (Prénoms)</MudSelectItem>
                <MudSelectItem Value="@("prenom-majuscule")">Majuscule (Prénoms)</MudSelectItem>
                @if (_ecolePublique)
                {
                    <MudSelectItem Value="@("inscrire")">Inscrire tous</MudSelectItem>
                    <MudSelectItem Value="@("desinscrire")">Désinscrire tous</MudSelectItem>
                }
                <MudSelectItem Value="@("lv2")">Copier LV_2</MudSelectItem>
                <MudSelectItem Value="@("arts")">Copier Arts</MudSelectItem>
                <MudSelectItem Value="@("serie")">Copier Série</MudSelectItem>
                <MudSelectItem Value="@("red")">Copier Red</MudSelectItem>
            </MudSelect>

            @if (BulkNeedsValeur)
            {
                <MudSelect T="string" @bind-Value="_bulkValeur" Dense="true" Margin="Margin.Dense"
                           Variant="Variant.Outlined" Class="lc-bulk-val" Style="width:145px" Placeholder="Valeur…">
                    @foreach (var v in BulkValeurOptions)
                    {
                        <MudSelectItem Value="@v">@v</MudSelectItem>
                    }
                </MudSelect>
            }

            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       OnClick="ExecuterOperationAsync" Disabled="_bulkEnCours" Class="lc-bulk-go">
                @if (_bulkEnCours)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                    <span>En cours…</span>
                }
                else
                {
                    <span>Go</span>
                }
            </MudButton>

            @* Jauge indéterminée pendant l'opération (le nombre d'élèves peut rendre le Go long). *@
            @if (_bulkEnCours)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="lc-bulk-progress" />
            }
        </div>

        @* ===== Activer colonne : rend une colonne normalement read-only éditable pour correction ===== *@
        <div class="lc-activer">
            <span class="lc-bulk-label">Activer colonne :</span>
            <MudSelect T="string" Value="_colonneActive" ValueChanged="OnColonneActiveChanged" Clearable="true"
                       Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined" Class="lc-bulk-op"
                       Style="width:185px" Placeholder="(aucune)">
                <MudSelectItem Value="@("cycle")">Cycle</MudSelectItem>
                <MudSelectItem Value="@("datenaiss")">Date naiss</MudSelectItem>
                <MudSelectItem Value="@("lieunaiss")">Lieu naiss</MudSelectItem>
                <MudSelectItem Value="@("nationalite")">Nationalité</MudSelectItem>
                <MudSelectItem Value="@("telephone")">Téléphone</MudSelectItem>
            </MudSelect>
            @if (!string.IsNullOrEmpty(_colonneActive))
            {
                <span class="lc-activer-hint">← colonne éditable : corrige directement dans la grille.</span>
            }
        </div>
        </div><!-- /lc-grid-col -->

        @* ============ Fiche Élève, à droite de la grille (calque du « Point de l'élève » du
               form Versements) : cadre photo d'identité (35×45) + état civil. ============ *@
        @if (_sel is not null)
        {
            <div class="lc-fiche-col">
                <div class="lc-fiche">
                    @* En-tête calqué sur le reçu de versement : école + année à gauche, logo au
                       centre, titre + date à droite. *@
                    <div class="lc-entete">
                        <div class="lc-entete-gauche">
                            <div class="lc-entete-ecole">@(string.IsNullOrWhiteSpace(_nomEcole) ? "ÉCOLE / ÉTABLISSEMENT" : _nomEcole)</div>
                            <div class="lc-entete-annee">Année scolaire : @_annee</div>
                        </div>
                        <div class="lc-entete-logo">
                            @if (!string.IsNullOrWhiteSpace(_logoEcole))
                            {
                                <img src="@_logoEcole" alt="Logo" />
                            }
                        </div>
                        <div class="lc-entete-droite">
                            <div class="lc-entete-titre">FICHE ÉLÈVE</div>
                            <div class="lc-entete-date">Date : @DateTime.Now.ToString("dd/MM/yyyy")</div>
                        </div>
                    </div>
                    <div class="lc-fiche-corps">
                        <div class="lc-photo-col">
                            <div class="lc-photo">
                                @{
                                    var src = PhotoSrc(_sel);
                                }
                                @if (src is not null)
                                {
                                    <img src="@src" alt="Photo de @_sel.Nom @_sel.Prenoms" />
                                }
                                else
                                {
                                    <div class="lc-photo-vide">
                                        <MudIcon Icon="@Icons.Material.Filled.PersonOutline" Size="Size.Large" />
                                        <div>Pas de photo</div>
                                    </div>
                                }
                            </div>
                            @* Bouton juste sous la photo : ouvre la fenêtre de fichiers Windows
                               (InputFile caché activé par le label). *@
                            <InputFile id="lc-photo-input" OnChange="OnPhotoSelected" accept="image/*" style="display:none" />
                            <MudTooltip Text="Ajouter une photo">
                                <MudButton HtmlTag="label" for="lc-photo-input"
                                           Variant="Variant.Outlined" Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.AddAPhoto"
                                           Class="lc-photo-btn">Ajouter</MudButton>
                            </MudTooltip>
                            <MudTooltip Text="Supprimer la photo">
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Error"
                                           StartIcon="@Icons.Material.Filled.Delete"
                                           Disabled="@string.IsNullOrEmpty(_sel.ImageFile)"
                                           OnClick="SupprimerPhoto"
                                           Class="lc-photo-btn">Supprimer</MudButton>
                            </MudTooltip>
                        </div>
                        <div class="lc-fiche-detail">
                            <div class="lc-nom">@_sel.Nom @_sel.Prenoms</div>
                            <div class="lc-grid">
                                <div class="lc-field"><span>N° Inscr.</span><b>@_sel.NumOrdre</b></div>
                                <div class="lc-field"><span>Sexe</span><b>@_sel.Sexe</b></div>
                                <div class="lc-field"><span>Né(e) le</span><b>@(_sel.DateNaissance?.ToString("dd/MM/yyyy"))</b></div>
                                <div class="lc-field"><span>Nationalité</span><b>@_sel.Nationalite</b></div>
                                <div class="lc-field lc-field-large"><span>Matricule</span><b>@FormatMatricule(_sel.Matricule)</b></div>
                                <div class="lc-field lc-field-large"><span>Lieu naiss.</span><b>@_sel.LieuNaissance</b></div>
                                <div class="lc-field"><span>Cycle</span><b>@_sel.Cycle</b></div>
                                <div class="lc-field"><span>Niveau</span><b>@_sel.Niveau</b></div>
                                <div class="lc-field"><span>Classe</span><b>@_sel.Classe</b></div>
                                <div class="lc-field"><span>Série</span><b>@_sel.Serie</b></div>
                                <div class="lc-field"><span>Statut</span><b>@_sel.Statut</b></div>
                                <div class="lc-field"><span>Inscrit</span><b>@(_sel.Inscrit ? "Oui" : "Non")</b></div>
                                <div class="lc-field"><span>Actif</span><b>@(_sel.Actif ? "Oui" : "Non")</b></div>
                                <div class="lc-field"><span>Tél.</span><b>@_sel.Telephone</b></div>
                            </div>
                        </div>
                    </div>

                    @* Tuteur : sous le corps (photo + détail), séparé par un trait pleine largeur. *@
                    <div class="lc-tuteur">
                        <div class="lc-tuteur-titre">Tuteur</div>
                        @* Tuteur éditable : persistance au blur (Immediate=false), rollback si échec. *@
                        <div class="lc-tuteur-corps">
                            @* Nom et Prénom concaténés sur la même ligne (deux champs côte à côte). *@
                            <div class="lc-field"><span>Nom</span>
                                <MudTextField Value="@_sel.TuteurNom" ValueChanged="@(v => OnTuteurChanged("Nom", v))"
                                              T="string" Immediate="false" Margin="Margin.Dense"
                                              Variant="Variant.Text" Class="lc-tuteur-input" />
                                <MudTextField Value="@_sel.TuteurPrenom" ValueChanged="@(v => OnTuteurChanged("Prenom", v))"
                                              T="string" Immediate="false" Margin="Margin.Dense"
                                              Variant="Variant.Text" Class="lc-tuteur-input" />
                            </div>
                            <div class="lc-field"><span>Tél.</span>
                                <MudTextField Value="@_sel.TuteurTel1" ValueChanged="@(v => OnTuteurChanged("Tel1", v))"
                                              T="string" Immediate="false" Margin="Margin.Dense"
                                              Variant="Variant.Text" Class="lc-tuteur-input" />
                            </div>
                            <div class="lc-field"><span>WhatsApp</span>
                                <MudTextField Value="@_sel.TuteurTel2" ValueChanged="@(v => OnTuteurChanged("Tel2", v))"
                                              T="string" Immediate="false" Margin="Margin.Dense"
                                              Variant="Variant.Text" Class="lc-tuteur-input" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        </div><!-- /lc-layout -->

    </div>
</MudPaper>

@* ==================== Aperçu avant impression de la liste de classe ====================
   Overlay HTML pur (aucun composant MudBlazor dans la feuille) : le CSS scopé s'applique
   sans piège, et l'impression (@media print, index.html) n'a qu'à isoler « .lc-feuille ».
   Clic sur le fond = fermer ; clic dans la feuille = neutralisé (stopPropagation). *@
@if (_apercuOuvert)
{
    <div class="lc-preview-overlay" @onclick="FermerApercu">
        <div class="lc-preview-panel @(ModeleEstPaysage ? "lc-preview-panel--paysage" : "")" @onclick:stopPropagation="true">
            <div class="lc-preview-toolbar">
                <div class="d-flex align-center gap-3">
                    <span class="lc-preview-titre">Aperçu</span>
                    <div class="lc-preview-modele">
                        <label class="lc-preview-modele-label">Modèle :</label>
                        <MudSelect T="ModeleListe" Value="_modele" ValueChanged="OnModeleChanged"
                                   Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
                                   Class="lc-preview-modele-field">
                            <MudSelectItem Value="@ModeleListe.Classe">Liste de classe</MudSelectItem>
                            <MudSelectItem Value="@ModeleListe.Affectes">Liste des affectés</MudSelectItem>
                            <MudSelectItem Value="@ModeleListe.Appel">Liste d'appel (présence)</MudSelectItem>
                            <MudSelectItem Value="@ModeleListe.Notes">Fiche de notes</MudSelectItem>
                            <MudSelectItem Value="@ModeleListe.Trombinoscope">Trombinoscope</MudSelectItem>
                        </MudSelect>
                    </div>
                </div>
                <div class="d-flex align-center gap-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Print"
                               OnClick="ImprimerListeAsync">Imprimer</MudButton>
                    <MudButton Variant="Variant.Outlined" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Close"
                               OnClick="FermerApercu">Fermer</MudButton>
                </div>
            </div>

            @* La feuille A4 : SEUL élément conservé à l'impression. *@
            <div class="lc-feuille @(ModeleEstPaysage ? "lc-feuille--paysage" : "")">
                <div class="lc-feuille-entete">
                    @* Gauche : autorité de tutelle. *@
                    <div class="lc-feuille-ministere">
                        <div class="lc-feuille-min-titre">RÉPUBLIQUE DE CÔTE D'IVOIRE</div>
                        <div class="lc-feuille-dren">MENA-DREN : <b>@_villeEcole</b></div>
                    </div>
                    @* Centre : logo de l'école. *@
                    @if (!string.IsNullOrWhiteSpace(_logoEcole))
                    {
                        <div class="lc-feuille-logo"><img src="@_logoEcole" alt="Logo" /></div>
                    }
                    @* Droite : école + année scolaire. *@
                    <div class="lc-feuille-ecole-droite">
                        <div class="lc-feuille-nom">@(string.IsNullOrWhiteSpace(_nomEcole) ? "ÉCOLE / ÉTABLISSEMENT" : _nomEcole)</div>
                        <div class="lc-feuille-annee">Année scolaire : @_annee</div>
                    </div>
                </div>

                @* Ligne : titre (classe) à gauche, stats à droite. *@
                <div class="lc-feuille-barre">
                    <div class="lc-feuille-titre">@ModeleTitre@(string.IsNullOrWhiteSpace(_fClasse) ? "" : $" : {FormatClasse(_fClasse)}")</div>
                    <div class="lc-feuille-totaux">
                        <span>Garçons : <b>@NbGarcons</b></span>
                        <span>Filles : <b>@NbFilles</b></span>
                        <span>Total : <b>@ElevesImpression.Count</b></span>
                    </div>
                </div>

                @* ---- Corps selon le modèle. En-tête, stats et impression sont communs. ---- *@
                @if (_modele == ModeleListe.Appel)
                {
                    @* Cahier d'appel hebdomadaire (LISTE DE PRÉSENCE), paysage : jours × créneaux,
                       cases à cocher à la main. Bande « Semaine du… » + « Prof. Principal ». *@
                    <div class="lc-appel-band">
                        <span class="lc-appel-semaine">SEMAINE DU : ....../....../..........&nbsp;&nbsp;&nbsp;AU : ....../....../..........</span>
                        <span class="lc-appel-prof">Prof. Principal : ...................................</span>
                    </div>
                    <table class="lc-feuille-table lc-appel-table">
                        <thead>
                            <tr>
                                <th class="c-num" rowspan="2">N°</th>
                                <th class="c-mat" rowspan="2">Matricule</th>
                                <th class="c-nom" rowspan="2">Nom &amp; Prénoms</th>
                                @foreach (var jour in JoursAppel)
                                {
                                    <th class="lc-appel-jour" colspan="@CreneauxAppel.Length">@jour</th>
                                }
                            </tr>
                            <tr>
                                @foreach (var jour in JoursAppel)
                                {
                                    @foreach (var cr in CreneauxAppel)
                                    {
                                        <th class="lc-appel-creneau">@((MarkupString)cr.Replace(" ", "<br>"))</th>
                                    }
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @{ var rangA = 0; }
                            @foreach (var e in ElevesImpression)
                            {
                                rangA++;
                                <tr>
                                    <td class="c-num">@rangA</td>
                                    <td class="c-mat">@FormatMatricule(e.Matricule)</td>
                                    <td class="c-nom">@e.Nom @e.Prenoms</td>
                                    @foreach (var jour in JoursAppel)
                                    {
                                        @foreach (var cr in CreneauxAppel)
                                        {
                                            <td class="lc-appel-case"></td>
                                        }
                                    }
                                </tr>
                            }
                            @if (ElevesImpression.Count == 0)
                            {
                                <tr><td colspan="@(3 + JoursAppel.Length * CreneauxAppel.Length)" class="lc-feuille-vide">Aucun élève ne correspond au filtre.</td></tr>
                            }
                        </tbody>
                    </table>
                }
                else if (_modele == ModeleListe.Trombinoscope)
                {
                    @* Trombinoscope (paysage) : grille de cartes photo + Nom & Prénoms + Matricule. *@
                    <div class="lc-tromb">
                        @foreach (var e in ElevesImpression)
                        {
                            var src = PhotoSrc(e);
                            <div class="lc-tromb-carte">
                                <div class="lc-tromb-photo">
                                    @if (src is not null)
                                    {
                                        <img src="@src" alt="@e.Nom @e.Prenoms" />
                                    }
                                </div>
                                <div class="lc-tromb-nom">@e.Nom @e.Prenoms</div>
                                <div class="lc-tromb-mat">@FormatMatricule(e.Matricule)</div>
                            </div>
                        }
                        @if (ElevesImpression.Count == 0)
                        {
                            <div class="lc-feuille-vide">Aucun élève ne correspond au filtre.</div>
                        }
                    </div>
                }
                else
                {
                    @* Tableaux portrait : état civil (Liste de classe / Affectés) OU Fiche de notes
                       (Matricule + 7 colonnes vides à remplir à la main). *@
                    <table class="lc-feuille-table @(ModeleNotes ? "lc-feuille-table--saisie" : "")">
                        <thead>
                            <tr>
                                <th class="c-num">N°</th>
                                <th class="c-mat">Matricule</th>
                                <th class="c-nom">Nom &amp; Prénoms</th>
                                <th class="c-sexe">Sexe</th>
                                @if (ModeleNotes)
                                {
                                    @for (var k = 0; k < NbColonnesVides; k++)
                                    {
                                        <th class="c-vide"></th>
                                    }
                                }
                                else
                                {
                                    <th class="c-date">Date naiss.</th>
                                    <th class="c-lieu">Lieu naiss.</th>
                                    <th class="c-nat">Nationalité</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @{ var rang = 0; }
                            @foreach (var e in ElevesImpression)
                            {
                                rang++;
                                <tr>
                                    <td class="c-num">@rang</td>
                                    <td class="c-mat">@FormatMatricule(e.Matricule)</td>
                                    <td class="c-nom">@e.Nom @e.Prenoms</td>
                                    <td class="c-sexe">@e.Sexe</td>
                                    @if (ModeleNotes)
                                    {
                                        @for (var k = 0; k < NbColonnesVides; k++)
                                        {
                                            <td class="c-vide"></td>
                                        }
                                    }
                                    else
                                    {
                                        <td class="c-date">@(e.DateNaissance?.ToString("dd/MM/yyyy"))</td>
                                        <td class="c-lieu">@e.LieuNaissance</td>
                                        <td class="c-nat">@e.Nationalite</td>
                                    }
                                </tr>
                            }
                            @if (ElevesImpression.Count == 0)
                            {
                                <tr><td colspan="@(ModeleNotes ? 4 + NbColonnesVides : 7)" class="lc-feuille-vide">Aucun élève ne correspond au filtre.</td></tr>
                            }
                        </tbody>
                    </table>
                }

                @* Date d'édition en bas de la liste. *@
                <div class="lc-feuille-pied">Édité le : @DateTime.Now.ToString("dd/MM/yyyy")</div>
            </div>
        </div>
    </div>
}
