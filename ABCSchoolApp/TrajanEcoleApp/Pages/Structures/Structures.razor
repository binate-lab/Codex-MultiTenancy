@page "/structures"
@layout SchoolLayout
@using global::App.Infrastructure.Services.Structures

<MudPaper Elevation="6" Class="ma-2">
    <MudToolBar Dense="true" Class="px-3" Style="background-color:#1b4f72; color:white;">
        <MudIcon Icon="@Icons.Material.Outlined.AccountTree" Class="mr-2" />
        <MudText Typo="Typo.h6">Cycles, niveaux &amp; classes</MudText>
        <MudSpacer />
        <MudText Typo="Typo.subtitle2" Class="mr-4">@_annee</MudText>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Inherit"
                   OnClick="@(() => _navigation.NavigateTo("/ecole"))">Fermer</MudButton>
    </MudToolBar>

    <MudTabs Elevation="0" ApplyEffectsToContainer="true" PanelClass="pa-4" KeepPanelsAlive="true">

        @* ------------------------------- CYCLES & NIVEAUX ------------------------------- *@
        <MudTabPanel Text="Cycles & niveaux" Icon="@Icons.Material.Outlined.AccountTree">
            <MudGrid Spacing="4">
                <MudItem xs="12" md="5">
                    <MudText Typo="Typo.subtitle1" Class="mb-2" Style="font-weight:600;">Cycles</MudText>

                    @* Enregistrement direct façon Access : la modification part en base
                       à la sortie de la cellule (si la valeur a changé). *@
                    <div class="str-grid">
                        <MudTable Items="_cycles" Dense="true" Hover="true" Elevation="1" Bordered="true">
                            <HeaderContent>
                                <MudTh Style="width:70px;">N°</MudTh>
                                <MudTh>Libellé</MudTh>
                                <MudTh Style="width:90px;">Niveaux</MudTh>
                                <MudTh Style="width:80px; text-align:right;">Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    <MudNumericField T="int" @bind-Value="context.Numero" Margin="Margin.Dense" Variant="Variant.Text" HideSpinButtons="true"
                                                     OnBlur="@(() => EnregistrerCycleSiModifieAsync(context))" />
                                </MudTd>
                                <MudTd>
                                    <MudTextField T="string" @bind-Value="context.Libelle" Margin="Margin.Dense" Variant="Variant.Text"
                                                  OnBlur="@(() => EnregistrerCycleSiModifieAsync(context))" />
                                </MudTd>
                                <MudTd Style="text-align:center;">@context.NbNiveaux</MudTd>
                                <MudTd Style="text-align:right;">
                                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Color="Color.Secondary"
                                             TransformOrigin="Origin.BottomLeft" AnchorOrigin="Origin.BottomLeft">
                                        <MudMenuItem OnClick="@(() => SupprimerCycleAsync(context))">Supprimer</MudMenuItem>
                                    </MudMenu>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>

                    <MudStack Row="true" Spacing="2" Class="str-addbar" AlignItems="AlignItems.Center">
                        <MudNumericField T="int" @bind-Value="_nouveauCycleNumero" Label="N°" Margin="Margin.Dense"
                                         Variant="Variant.Outlined" HideSpinButtons="true" Style="max-width:80px;" />
                        <MudTextField T="string" @bind-Value="_nouveauCycleLibelle" Label="Libellé du cycle"
                                      Margin="Margin.Dense" Variant="Variant.Outlined" />
                        <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary"
                                   Size="Size.Small" OnClick="AjouterCycleAsync">Ajouter</MudButton>
                    </MudStack>
                </MudItem>

                <MudItem xs="12" md="7">
                    <MudText Typo="Typo.subtitle1" Class="mb-2" Style="font-weight:600;">Niveaux</MudText>

                    @* Cycle affiché par son N° (non éditable : un niveau ne change pas de cycle ici) ;
                       le code s'enregistre en base dès la sortie de la cellule (pas de disquette). *@
                    <div class="str-grid">
                        <MudTable Items="_niveaux" Dense="true" Hover="true" Elevation="1" Bordered="true">
                            <HeaderContent>
                                <MudTh Style="width:80px; text-align:center;">Cycle</MudTh>
                                <MudTh Style="width:110px;">Code</MudTh>
                                <MudTh Style="width:90px;">Classes</MudTh>
                                <MudTh Style="width:80px; text-align:right;">Actions</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd Style="text-align:center;">@context.CycleNumero</MudTd>
                                <MudTd>
                                    <MudTextField T="string" @bind-Value="context.Code" Margin="Margin.Dense" Variant="Variant.Text"
                                                  OnBlur="@(() => EnregistrerNiveauSiModifieAsync(context))" />
                                </MudTd>
                                <MudTd Style="text-align:center;">@context.NbClasses</MudTd>
                                <MudTd Style="text-align:right;">
                                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Color="Color.Secondary"
                                             TransformOrigin="Origin.BottomLeft" AnchorOrigin="Origin.BottomLeft">
                                        <MudMenuItem OnClick="@(() => SupprimerNiveauAsync(context))">Supprimer</MudMenuItem>
                                    </MudMenu>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>

                    @* Liste déroulante en 2 colonnes (N° + libellé) ; une fois choisi,
                       seul le N° du cycle est affiché dans la zone (ToStringFunc). *@
                    <MudStack Row="true" Spacing="2" Class="str-addbar" AlignItems="AlignItems.Center">
                        <MudSelect T="Guid?" @bind-Value="_nouveauNiveauCycleId" Label="Cycle" Margin="Margin.Dense"
                                   Variant="Variant.Outlined" Style="min-width:110px;"
                                   ToStringFunc="@AfficherNumeroCycle">
                            @foreach (var c in _cycles)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)c.Id)">
                                    <span style="display:inline-block; min-width:36px; font-weight:600;">@c.Numero</span>
                                    <span>@c.Libelle</span>
                                </MudSelectItem>
                            }
                        </MudSelect>
                        <MudTextField T="string" @bind-Value="_nouveauNiveauCode" Label="Code (ex. 6e)"
                                      Margin="Margin.Dense" Variant="Variant.Outlined" Style="max-width:120px;" />
                        <MudTextField T="string" @bind-Value="_nouveauNiveauLibelle" Label="Libellé (ex. Sixième)"
                                      Margin="Margin.Dense" Variant="Variant.Outlined" />
                        <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary"
                                   Size="Size.Small" OnClick="AjouterNiveauAsync">Ajouter</MudButton>
                    </MudStack>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* ------------------------------------ CLASSES ------------------------------------ *@
        <MudTabPanel Text="Classes" Icon="@Icons.Material.Outlined.MeetingRoom">
            <MudText Typo="Typo.subtitle2" Class="mb-3">Classes ouvertes pour l'année <b>@_annee</b></MudText>

            <div class="str-grid" style="max-width:800px;">
                <MudTable Items="_classes" Dense="true" Hover="true" Elevation="1" Bordered="true">
                    <HeaderContent>
                        <MudTh Style="width:160px;">Niveau</MudTh>
                        <MudTh>Libellé</MudTh>
                        <MudTh Style="width:120px;">Année</MudTh>
                        <MudTh Style="width:80px; text-align:right;">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            @* Enregistrement direct dès le choix d'un autre niveau (@bind:after). *@
                            <MudSelect T="Guid" @bind-Value="context.NiveauId" @bind-Value:after="@(() => EnregistrerClasseSiModifieeAsync(context))"
                                       Margin="Margin.Dense" Variant="Variant.Text">
                                @foreach (var n in _niveaux)
                                {
                                    <MudSelectItem T="Guid" Value="@n.Id">@n.Code</MudSelectItem>
                                }
                            </MudSelect>
                        </MudTd>
                        <MudTd>
                            <MudTextField T="string" @bind-Value="context.Libelle" Margin="Margin.Dense" Variant="Variant.Text"
                                          OnBlur="@(() => EnregistrerClasseSiModifieeAsync(context))" />
                        </MudTd>
                        <MudTd>@context.AnneeScolaire</MudTd>
                        <MudTd Style="text-align:right;">
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Color="Color.Secondary"
                                     TransformOrigin="Origin.BottomLeft" AnchorOrigin="Origin.BottomLeft">
                                <MudMenuItem OnClick="@(() => SupprimerClasseAsync(context))">Supprimer</MudMenuItem>
                            </MudMenu>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </div>

            <MudStack Row="true" Spacing="2" Class="str-addbar" AlignItems="AlignItems.Center" Style="max-width:800px;">
                <MudSelect T="Guid?" @bind-Value="_nouvelleClasseNiveauId" Label="Niveau" Margin="Margin.Dense"
                           Variant="Variant.Outlined" Style="min-width:150px;">
                    @foreach (var n in _niveaux)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)n.Id)">@n.Code — @n.Libelle</MudSelectItem>
                    }
                </MudSelect>
                <MudTextField T="string" @bind-Value="_nouvelleClasseLibelle" Label="Libellé (ex. 6e A)"
                              Margin="Margin.Dense" Variant="Variant.Outlined" />
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary"
                           Size="Size.Small" OnClick="AjouterClasseAsync">Ajouter</MudButton>
            </MudStack>
        </MudTabPanel>
    </MudTabs>
</MudPaper>
