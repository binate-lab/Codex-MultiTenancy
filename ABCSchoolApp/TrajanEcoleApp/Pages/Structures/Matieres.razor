@page "/matieres"
@layout SchoolLayout
@using global::App.Infrastructure.Services.Structures

<MudPaper Elevation="6" Class="ma-2">
    <MudToolBar Dense="true" Class="px-3" Style="background-color:#1b4f72; color:white;">
        <MudIcon Icon="@Icons.Material.Outlined.MenuBook" Class="mr-2" />
        <MudText Typo="Typo.h6">Matières</MudText>
        <MudSpacer />
        <MudText Typo="Typo.subtitle2" Class="mr-4">@_annee</MudText>
        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Inherit"
                   OnClick="@(() => _navigation.NavigateTo("/ecole"))">Fermer</MudButton>
    </MudToolBar>

    <div class="pa-4">
        <div class="mat-grid" style="max-width:700px;">
            <MudTable Items="_matieres" Dense="true" Hover="true" Elevation="1" Bordered="true">
                <HeaderContent>
                    <MudTh Style="width:150px;">Code</MudTh>
                    <MudTh>Libellé</MudTh>
                    <MudTh Style="width:80px; text-align:right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    @* Enregistrement direct façon Access : part en base à la sortie de la cellule. *@
                    <MudTd>
                        <MudTextField T="string" @bind-Value="context.Code" Margin="Margin.Dense" Variant="Variant.Text"
                                      OnBlur="@(() => EnregistrerMatiereSiModifieeAsync(context))" />
                    </MudTd>
                    <MudTd>
                        <MudTextField T="string" @bind-Value="context.Libelle" Margin="Margin.Dense" Variant="Variant.Text"
                                      OnBlur="@(() => EnregistrerMatiereSiModifieeAsync(context))" />
                    </MudTd>
                    <MudTd Style="text-align:right;">
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Color="Color.Secondary"
                                 TransformOrigin="Origin.BottomLeft" AnchorOrigin="Origin.BottomLeft">
                            <MudMenuItem OnClick="@(() => SupprimerMatiereAsync(context))">Supprimer</MudMenuItem>
                        </MudMenu>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </div>

        <MudStack Row="true" Spacing="2" Class="mat-addbar" AlignItems="AlignItems.Center" Style="max-width:700px;">
            <MudTextField T="string" @bind-Value="_nouvelleMatiereCode" Label="Code (ex. MATH)"
                          Margin="Margin.Dense" Variant="Variant.Outlined" Style="max-width:150px;" />
            <MudTextField T="string" @bind-Value="_nouvelleMatiereLibelle" Label="Libellé (ex. Mathématiques)"
                          Margin="Margin.Dense" Variant="Variant.Outlined" />
            <MudTooltip Text="Ajouter">
                <MudFab StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" IconSize="Size.Medium"
                        OnClick="AjouterMatiereAsync" />
            </MudTooltip>
        </MudStack>
    </div>
</MudPaper>
