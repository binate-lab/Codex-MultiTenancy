@page "/paiements-orange"
@layout SchoolLayout

<MudPaper Elevation="6" Class="ma-2">
    <MudToolBar Dense="true" Class="px-3" Style="background-color:#e67e22; color:white;">
        <MudIcon Icon="@Icons.Material.Outlined.Payments" Class="mr-2" />
        <MudText Typo="Typo.h6">Orange Money — Paiements reçus</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Inherit"
                   OnClick="Fermer">Fermer</MudButton>
    </MudToolBar>

    <div class="pa-4">
        <MudText Typo="Typo.body2" Class="mb-3 mud-text-secondary" Style="max-width:820px;">
            Paiements notifiés par Orange Money. Un paiement <b>en attente</b> a été rattaché à un élève :
            validez-le pour l'imputer sur son échéancier. Un <b>orphelin</b> n'a pas trouvé d'élève
            (matricule inconnu) : rattachez-le au bon élève avant validation.
        </MudText>

        <div class="d-flex align-center gap-3 mb-3" style="max-width:420px;">
            <MudSelect T="string" @bind-Value="_statut" Label="Statut" Dense="true"
                       Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value:after="ChargerAsync">
                <MudSelectItem Value="@("EnAttente")">En attente</MudSelectItem>
                <MudSelectItem Value="@("Orphelin")">Orphelins</MudSelectItem>
                <MudSelectItem Value="@("Valide")">Validés</MudSelectItem>
                <MudSelectItem Value="@("Rejete")">Rejetés</MudSelectItem>
                <MudSelectItem Value="@("")">Tous</MudSelectItem>
            </MudSelect>
            <MudTooltip Text="Rafraîchir">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Primary"
                               Disabled="_enCours" OnClick="ChargerAsync" />
            </MudTooltip>
        </div>

        @* Grille bornee en largeur : sans max-width, la table s'etire sur tout l'ecran et
           l'espace excedentaire gonfle les colonnes libres (Nom, Montant, Reference). *@
        @* Wrapper indispensable : c'est LUI qui porte le scope Blazor (::deep), pas la MudTable. *@
        <div class="pmt-grid">
        <MudTable Items="_lignes" Dense="true" Hover="true" Bordered="true" Striped="true" Loading="_enCours"
                  RowsPerPage="15" Style="max-width:1440px;">
            <HeaderContent>
                <MudTh Style="width:150px; white-space:nowrap;">Reçu le</MudTh>
                <MudTh Style="width:95px;">Date paiement</MudTh>
                <MudTh Style="width:95px;">Matricule</MudTh>
                <MudTh>Nom & Prénoms</MudTh>
                <MudTh Style="width:110px; text-align:right;">Montant</MudTh>
                <MudTh Style="width:200px;">N° payeur</MudTh>
                <MudTh Style="width:160px;">Référence</MudTh>
                <MudTh Style="width:170px; text-align:center;">Statut</MudTh>
                <MudTh Style="width:56px; text-align:center;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Reçu le" Style="white-space:nowrap;">@context.ReceivedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
                <MudTd DataLabel="Date paiement">@context.DatePaiement.ToString("dd/MM/yyyy")</MudTd>
                <MudTd DataLabel="Matricule">@context.Matricule</MudTd>
                <MudTd DataLabel="Nom & Prénoms">
                    @if (!string.IsNullOrWhiteSpace(context.EleveNomComplet))
                    {
                        @* Élève réellement rattaché (identité de référence) *@
                        <span>@context.EleveNomComplet</span>
                        @if (NomDeclareDiffere(context))
                        {
                            <MudTooltip Text="@($"⚠ Orange a déclaré « {context.Nom} {context.Prenoms} » — nom différent de l'élève rattaché.")">
                                <MudIcon Icon="@Icons.Material.Filled.WarningAmber" Size="Size.Small"
                                         Color="Color.Warning" Class="ml-1" Style="vertical-align:middle;" />
                            </MudTooltip>
                        }
                    }
                    else
                    {
                        @* Orphelin : pas d'élève rattaché → on affiche le nom déclaré par Orange *@
                        <span class="mud-text-secondary" style="font-style:italic;">@context.Nom @context.Prenoms</span>
                        <MudTooltip Text="Nom déclaré par Orange (aucun élève rattaché).">
                            <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Size="Size.Small"
                                     Color="Color.Default" Class="ml-1" Style="vertical-align:middle;" />
                        </MudTooltip>
                    }
                </MudTd>
                <MudTd DataLabel="Montant" Style="text-align:right; white-space:nowrap;">@Fmt(context.Montant)F</MudTd>
                <MudTd DataLabel="N° payeur" Style="white-space:nowrap;">
                    @if (!string.IsNullOrWhiteSpace(context.NumeroPayeur))
                    {
                        <span style="font-family:monospace;">@context.NumeroPayeur</span>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                 Color="@CouleurLien(context.LienPayeur)" Class="ml-1">
                            @LibelleLien(context.LienPayeur)
                        </MudChip>
                    }
                    else
                    {
                        <span class="mud-text-secondary">—</span>
                    }
                </MudTd>
                <MudTd DataLabel="Référence">@context.Reference</MudTd>
                <MudTd DataLabel="Statut" Style="text-align:center;">
                    <MudChip T="string" Size="Size.Small" Color="@CouleurStatut(context.Statut)"
                             Variant="Variant.Filled">@LibelleStatut(context.Statut)</MudChip>
                    @if (!string.IsNullOrWhiteSpace(context.ModeValidation))
                    {
                        <MudTooltip Text="@(context.ModeValidation == "A"
                            ? "Validé automatiquement (imputé sur l'enfant du matricule)."
                            : "Validé manuellement : montant réparti par le caissier dans Versements.")">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                     Color="@(context.ModeValidation == "A" ? Color.Success : Color.Warning)">
                                @context.ModeValidation
                            </MudChip>
                        </MudTooltip>
                    }
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align:center;">
                    @if (context.Statut is "EnAttente" or "Orphelin")
                    {
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Color="Color.Secondary"
                                 TransformOrigin="Origin.BottomLeft" AnchorOrigin="Origin.BottomLeft">
                            @if (context.Statut == "EnAttente")
                            {
                                <MudMenuItem Disabled="_enCours" OnClick="@(() => ValiderAsync(context))">Valider Auto</MudMenuItem>
                                <MudMenuItem Disabled="_enCours" OnClick="@(() => ValiderManuAsync(context))">Valider Manu</MudMenuItem>
                            }
                            @if (context.Statut == "Orphelin")
                            {
                                <MudMenuItem Disabled="_enCours" OnClick="@(() => RattacherAsync(context))">Rattacher à un élève</MudMenuItem>
                            }
                            <MudMenuItem Disabled="_enCours" OnClick="@(() => RejeterAsync(context))">Rejeter</MudMenuItem>
                        </MudMenu>
                    }
                    else if (!string.IsNullOrWhiteSpace(context.Note))
                    {
                        <MudTooltip Text="@context.Note">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" />
                        </MudTooltip>
                    }
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Class="pa-2">Aucun paiement pour ce filtre.</MudText>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager PageSizeOptions="@(new int[] { 15, 25, 50, 100 })"
                               RowsPerPageString="Lignes par page"
                               InfoFormat="{first_item}-{last_item} sur {all_items}" />
            </PagerContent>
        </MudTable>
        </div>
    </div>
</MudPaper>
