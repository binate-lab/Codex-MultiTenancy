@page "/eleves/create"

<MudCard Elevation="25" Class="pa-4">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-2 mb-n1" />
                Nouvel eleve
            </MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Cree un eleve via le microservice Eleves.Api (propage l'evenement aux autres services).
            </MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudForm @ref="_form" Model="Eleve" Validation="@(_validator.ValidateValue)" ValidationDelay="0">
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="Eleve.NumeroMatricule" For="@(() => Eleve.NumeroMatricule)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Label="Matricule" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="Eleve.MatriculeInterne" For="@(() => Eleve.MatriculeInterne)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Label="Matricule interne" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="Eleve.AnneeScolaire" For="@(() => Eleve.AnneeScolaire)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Label="Annee scolaire" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="Eleve.Nom" For="@(() => Eleve.Nom)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Label="Nom" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="Eleve.Prenom" For="@(() => Eleve.Prenom)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Label="Prenom" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="Eleve.Cycle" For="@(() => Eleve.Cycle)"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Label="Cycle">
                        <MudSelectItem Value="1">1 - College</MudSelectItem>
                        <MudSelectItem Value="2">2 - Lycee</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect @bind-Value="Eleve.Niveau" For="@(() => Eleve.Niveau)"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Label="Niveau">
                        @foreach (var niveau in _niveaux)
                        {
                            <MudSelectItem Value="@niveau">@niveau</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="Eleve.Classe" For="@(() => Eleve.Classe)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Label="Classe" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudDatePicker @bind-Date="Eleve.DateNaissance"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Label="Date de naissance" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="Eleve.Sexe" For="@(() => Eleve.Sexe)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Label="Sexe" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="Eleve.LieuDeNaissance" For="@(() => Eleve.LieuDeNaissance)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Label="Lieu de naissance" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="Eleve.CodeEts" For="@(() => Eleve.CodeEts)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Label="Code Ets (ecole)" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudCardContent>
    <MudCardActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined" Class="mr-auto">Annuler</MudButton>
        <MudButton OnClick="SubmitAsync" Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="_isSaving">
            @if (_isSaving)
            {
                <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
            }
            Enregistrer
        </MudButton>
    </MudCardActions>
</MudCard>
