@inherits LayoutComponentBase

<AuthorizeView>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="height: 100vh">
            <MudPaper Elevation="0" Class="py-4" Style="width: 500px">
                <MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
                    @Body
                </MudContainer>
            </MudPaper>
        </MudContainer>
    </NotAuthorized>
    <Authorized>
        <MudLayout>
            <MudAppBar Style="background-color: #4EC9B0; color: white;">
                <MudText Typo="Typo.h6" Class="ml-2">Trajan</MudText>
                <MudIconButton Icon="@Icons.Material.Outlined.Menu" 
                    OnClick="@(ToggleDrawer)"
                    Class="ml-2" 
                    Edge="Edge.Start"/>
                <MudSpacer/>
                <MudText Typo="Typo.body2" Class="mr-3 d-none d-sm-flex">@(context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value)</MudText>
                <MudMenu Icon="@Icons.Material.Outlined.Person"
                    Color="Color.Inherit" 
                    AnchorOrigin="Origin.BottomLeft"
                    TransformOrigin="Origin.TopLeft" 
                    Dense="true"
                    Class="mt-1 ml-4">
                    <ChildContent>
                        <CurrentUserCard/>
                        <MudDivider/>
                        <MudMenuItem OnClick="LogoutDialog" Icon="@Icons.Material.Filled.Logout">Quitter</MudMenuItem>
                    </ChildContent>
                </MudMenu>
            </MudAppBar>
            <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always">
                <NavMenu/>
            </MudDrawer>
            <MudMainContent>
                <MudContainer MaxWidth="MaxWidth.False" Class="mt-1">
                    @Body
                </MudContainer>
            </MudMainContent>
            <ChatWidget />
        </MudLayout>
    </Authorized>
</AuthorizeView>

