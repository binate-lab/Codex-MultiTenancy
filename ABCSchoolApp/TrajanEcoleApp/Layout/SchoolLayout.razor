@inherits LayoutComponentBase

<AuthorizeView>
    <NotAuthorized>
        <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="height: 100vh">
            <MudPaper Elevation="0" Class="py-4" Style="width: 500px">
                <MudContainer MaxWidth="MaxWidth.False" Class="mt-4">
                    @Body
                </MudContainer>
            </MudPaper>
        </MudContainer>
    </NotAuthorized>
    <Authorized>
        <MudLayout Class="school-shell">
            <MudAppBar Style="background-image: url('/images/appbar.png'); background-size: cover; background-position: center; color: white;">
                <MudText Typo="Typo.h6" Class="ml-2">Trajan</MudText>
                <MudIconButton Icon="@Icons.Material.Outlined.Menu"
                    OnClick="@(ToggleDrawer)"
                    Color="Color.Inherit"
                    Class="ml-2"
                    Edge="Edge.Start" />
                <MudSpacer />
                <MudText Typo="Typo.body2" Class="mr-3 d-none d-sm-flex">@(context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value)</MudText>
                <MudMenu Icon="@Icons.Material.Outlined.Person"
                    Color="Color.Inherit"
                    AnchorOrigin="Origin.BottomLeft"
                    TransformOrigin="Origin.TopLeft"
                    Dense="true"
                    Class="mt-1 ml-4">
                    <ChildContent>
                        <CurrentUserCard />
                        <MudDivider />
                        <MudMenuItem OnClick="LogoutDialog" Icon="@Icons.Material.Filled.Logout">Quitter</MudMenuItem>
                    </ChildContent>
                </MudMenu>
            </MudAppBar>
            <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always">
                <SchoolNavMenu />
            </MudDrawer>
            <MudMainContent>
                @* Barre de menus / outils horizontale, fine, sous le bandeau.
                   Affichée UNIQUEMENT sur la page principale de l'espace école (/ecole).
                   Quand une page s'ouvre (ex. Création élève), elle disparaît et le
                   contenu remonte à sa place. *@
                @if (IsSchoolHome)
                {
                    <MudToolBar Dense="true" Class="school-submenu px-2 gap-1">
                        <MudMenu Label="Structure"
                                 StartIcon="@Icons.Material.Outlined.Apps"
                                 Size="Size.Small"
                                 Color="Color.Inherit"
                                 Dense="true">
                            @* Sous-menus (MudBlazor 8 : un MudMenu imbriqué devient un
                               élément avec flèche, ouvert au survol). D'autres entrées
                               viendront s'ajouter dans chaque groupe. *@
                            <MudMenu Label="Pédagogie"
                                     StartIcon="@Icons.Material.Outlined.School"
                                     Dense="true">
                                <MudMenuItem Href="/structures" Icon="@Icons.Material.Outlined.AccountTree">
                                    Cycles, niveaux &amp; classes
                                </MudMenuItem>
                                <MudMenuItem Href="/matieres" Icon="@Icons.Material.Outlined.MenuBook">
                                    Matières
                                </MudMenuItem>
                            </MudMenu>
                            <MudMenu Label="Economat"
                                     StartIcon="@Icons.Material.Outlined.Payments"
                                     Dense="true">
                                <MudMenuItem Icon="@Icons.Material.Outlined.EventNote" Disabled="true">
                                    Échéancier (à venir)
                                </MudMenuItem>
                            </MudMenu>
                        </MudMenu>
                        <MudButton StartIcon="@Icons.Material.Outlined.Print"
                                   Size="Size.Small"
                                   Color="Color.Inherit">Imprimer</MudButton>
                        <MudButton StartIcon="@Icons.Material.Outlined.Hub"
                                   Size="Size.Small"
                                   Color="Color.Inherit">Réseau</MudButton>
                        <MudMenu Label="Outils"
                                 StartIcon="@Icons.Material.Outlined.Build"
                                 Size="Size.Small"
                                 Color="Color.Inherit"
                                 Dense="true">
                            <MudMenuItem>Paramètres</MudMenuItem>
                            <MudMenuItem>Exporter</MudMenuItem>
                        </MudMenu>
                        <MudSpacer />
                    </MudToolBar>
                }
                @Body
            </MudMainContent>
            <ChatWidget />
        </MudLayout>
    </Authorized>
</AuthorizeView>
